// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "./client"
}

datasource db {
  provider = "postgresql"
}

model Message {
  id        Int      @id @default(autoincrement())
  nombre    String
  telefono  String
  servicio  String
  mensaje   String
  createdAt DateTime @default(now())
}

model WorkType {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  duration    Int      @default(60) // Duration in minutes
  price       Float    @default(10)  // Price in USD
  visits      Visit[]
  isActive    Boolean  @default(true)
}

enum VisitStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model Visit {
  id              Int         @id @default(autoincrement())
  nombre          String
  telefono        String
  email           String?
  date            DateTime    // The date and time of the visit
  workTypeId      Int
  workType        WorkType    @relation(fields: [workTypeId], references: [id])
  mensaje         String?
  status          VisitStatus @default(PENDING)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  stripeSessionId String?     @unique // Stripe Checkout Session ID for idempotency
  stripeEventId   String?     // Stripe Event ID for audit trail

  @@index([date, status])
}

model Availability {
  id        Int    @id @default(autoincrement())
  dayOfWeek Int    // 0 = Sunday, 1 = Monday, ..., 6 = Saturday
  startTime String // Format "HH:mm"
  endTime   String // Format "HH:mm"
}

model BlockedDate {
  id     Int      @id @default(autoincrement())
  date   DateTime @unique
  reason String?
}

model RateLimit {
  id        Int      @id @default(autoincrement())
  key       String   // "endpoint:ip"
  count     Int      @default(1)
  resetAt   DateTime // When the window expires

  @@unique([key])
  @@index([resetAt])
}

model RevokedToken {
  id        Int      @id @default(autoincrement())
  jti       String   @unique // JWT ID from session token
  revokedAt DateTime @default(now())

  @@index([revokedAt])
}

model StripeEventLog {
  id          Int      @id @default(autoincrement())
  eventId     String   @unique // Stripe event ID (evt_...)
  eventType   String   // e.g. checkout.session.completed
  status      String   // processing, completed, failed
  sessionId   String?  // Associated checkout session ID
  visitId     Int?     // Associated visit ID (if fulfillment created one)
  error       String?  // Error message if failed
  createdAt   DateTime @default(now())

  @@index([status])
  @@index([sessionId])
}
