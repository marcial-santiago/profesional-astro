// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "./client"
}

datasource db {
  provider = "postgresql"
}

model Message {
  id        Int      @id @default(autoincrement())
  nombre    String
  telefono  String
  servicio  String
  mensaje   String
  createdAt DateTime @default(now())
}

model WorkType {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  duration    Int      @default(60) // Duration in minutes
  price       Float    @default(10)  // Price in USD
  visits      Visit[]
  isActive    Boolean  @default(true)
}

enum VisitStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model Visit {
  id         Int         @id @default(autoincrement())
  nombre     String
  telefono   String
  email      String?
  date       DateTime    // The date and time of the visit
  workTypeId Int
  workType   WorkType    @relation(fields: [workTypeId], references: [id])
  mensaje    String?
  status     VisitStatus @default(PENDING)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([date, status])
}

model Availability {
  id        Int    @id @default(autoincrement())
  dayOfWeek Int    // 0 = Sunday, 1 = Monday, ..., 6 = Saturday
  startTime String // Format "HH:mm"
  endTime   String // Format "HH:mm"
}

model BlockedDate {
  id     Int      @id @default(autoincrement())
  date   DateTime @unique
  reason String?
}
