---
// VisitScheduler.astro - Versión mejorada con diseño moderno

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div
  id="visit-scheduler"
  class:list={[
    "w-full max-w-4xl mx-auto bg-white rounded-2xl shadow-lg overflow-hidden border border-slate-200",
    className,
  ]}
>
  <div class="md:flex">
    <!-- Sidebar con gradiente más suave -->
    <aside
      class="md:w-1/3 bg-gradient-to-br from-slate-800 to-slate-900 p-6 text-white"
    >
      <h2 class="text-xl font-bold mb-6">Agenda tu visita</h2>

      <nav class="space-y-4" aria-label="Pasos del agendamiento">
        {
          [
            { num: 1, title: "Servicio", desc: "¿Qué necesitas?" },
            { num: 2, title: "Fecha y Hora", desc: "Elige cuándo" },
            { num: 3, title: "Tus Datos", desc: "Información de contacto" },
          ].map(({ num, title, desc }) => (
            <div
              class:list={[
                "flex items-center gap-3 step-indicator transition-all duration-300",
                { active: num === 1 },
              ]}
              data-step={num}
            >
              <span
                class:list={[
                  "step-badge w-7 h-7 rounded-full border-2 flex items-center justify-center text-sm font-bold transition-all duration-300",
                  num === 1
                    ? "bg-blue-500 border-blue-500"
                    : "border-slate-600 text-slate-400",
                ]}
              >
                {num}
              </span>
              <div>
                <p class="text-sm font-medium">{title}</p>
                <p class="text-xs text-slate-400">{desc}</p>
              </div>
            </div>
          ))
        }
      </nav>

      <div class="mt-12 p-3 bg-slate-700/50 rounded-lg">
        <p class="text-xs text-slate-300 leading-relaxed">
          💡 Confirmamos tu turno en menos de 24 horas.
        </p>
      </div>
    </aside>

    <!-- Main Content Area -->
    <main class="md:w-2/3 p-6">
      <!-- Step 1: Work Type Selection -->
      <section
        id="step-1"
        class="scheduler-step"
        aria-labelledby="step-1-title"
      >
        <h3 id="step-1-title" class="text-lg font-semibold mb-4 text-slate-800">
          ¿Qué servicio necesitas?
        </h3>

        <div
          id="work-types-grid"
          class="space-y-2 max-h-[320px] overflow-y-auto pr-2"
          role="radiogroup"
        >
          <!-- Loading skeleton -->
          <div class="flex flex-col gap-2">
            {
              [1, 2, 3].map(() => (
                <div class="h-14 bg-slate-100 rounded-lg animate-pulse" />
              ))
            }
          </div>
        </div>

        <div class="mt-6 flex justify-end">
          <button
            id="next-1"
            type="button"
            class="bg-blue-600 text-white px-5 py-2 rounded-lg text-sm font-medium hover:bg-blue-700 transition disabled:opacity-40 disabled:cursor-not-allowed"
            disabled
            aria-label="Continuar al siguiente paso"
          >
            Continuar →
          </button>
        </div>
      </section>

      <!-- Step 2: Calendar & Time Selection -->
      <section
        id="step-2"
        class="scheduler-step hidden"
        aria-labelledby="step-2-title"
      >
        <h3 id="step-2-title" class="text-lg font-semibold mb-4 text-slate-800">
          Elige fecha y hora
        </h3>

        <div class="grid md:grid-cols-2 gap-4">
          <!-- Calendar -->
          <div
            id="calendar-container"
            class="border border-slate-200 rounded-xl p-4 bg-slate-50"
            role="application"
            aria-label="Calendario"
          >
            <!-- Calendar will be rendered here -->
          </div>

          <!-- Time Slots -->
          <div class="border border-slate-200 rounded-xl p-4">
            <p class="text-sm font-medium mb-3 text-slate-700">
              Horarios disponibles
            </p>
            <div
              id="slots-grid"
              class="grid grid-cols-3 gap-2"
              role="radiogroup"
            >
              <div class="col-span-3 text-center py-8">
                <span class="text-3xl">📅</span>
                <p class="text-sm text-slate-400 mt-2">Selecciona una fecha</p>
              </div>
            </div>
          </div>
        </div>

        <div class="mt-6 flex justify-between items-center">
          <button
            id="back-2"
            type="button"
            class="text-slate-500 hover:text-slate-800 transition text-sm"
            aria-label="Volver"
          >
            ← Atrás
          </button>
          <button
            id="next-2"
            type="button"
            class="bg-blue-600 text-white px-5 py-2 rounded-lg text-sm font-medium hover:bg-blue-700 transition disabled:opacity-40 disabled:cursor-not-allowed"
            disabled
            aria-label="Continuar"
          >
            Continuar →
          </button>
        </div>
      </section>

      <!-- Step 3: Contact Details & Confirmation -->
      <section
        id="step-3"
        class="scheduler-step hidden"
        aria-labelledby="step-3-title"
      >
        <h3 id="step-3-title" class="text-lg font-semibold mb-4 text-slate-800">
          Completa tus datos
        </h3>

        <form id="booking-form" class="space-y-4" novalidate>
          <div class="grid md:grid-cols-2 gap-4">
            <div>
              <label
                for="nombre"
                class="block text-sm font-medium text-slate-700 mb-1"
              >
                Nombre <span class="text-red-500">*</span>
              </label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                required
                minlength="3"
                maxlength="100"
                class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition"
                placeholder="Tu nombre completo"
                aria-required="true"
              />
              <span class="error-message hidden text-xs text-red-500 mt-1"
              ></span>
            </div>

            <div>
              <label
                for="telefono"
                class="block text-sm font-medium text-slate-700 mb-1"
              >
                Teléfono <span class="text-red-500">*</span>
              </label>
              <input
                type="tel"
                id="telefono"
                name="telefono"
                required
                pattern="[\d\s\+\-\(\)]{8,20}"
                class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition"
                placeholder="+54 9 351 123 4567"
                aria-required="true"
              />
              <span class="error-message hidden text-xs text-red-500 mt-1"
              ></span>
            </div>
          </div>

          <div>
            <label
              for="mensaje"
              class="block text-sm font-medium text-slate-700 mb-1"
            >
              Nota adicional <span class="text-slate-400">(opcional)</span>
            </label>
            <textarea
              id="mensaje"
              name="mensaje"
              rows="2"
              maxlength="500"
              class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition resize-none"
              placeholder="Contanos brevemente qué necesitas..."></textarea>
          </div>

          <!-- Summary Box -->
          <div
            class="bg-gradient-to-r from-blue-50 to-indigo-50 p-4 rounded-xl border border-blue-100"
          >
            <h4
              class="text-sm font-bold text-blue-800 mb-2 flex items-center gap-2"
            >
              <span>📋</span> Resumen de tu turno
            </h4>
            <ul id="summary-list" class="text-sm text-blue-700 space-y-1">
              <!-- Summary will be populated here -->
            </ul>
          </div>

          <div class="flex justify-between items-center pt-2">
            <button
              type="button"
              id="back-3"
              class="text-slate-500 hover:text-slate-800 transition text-sm"
              aria-label="Volver"
            >
              ← Atrás
            </button>
            <button
              type="submit"
              class="bg-green-600 text-white px-6 py-2.5 rounded-lg text-sm font-bold hover:bg-green-700 transition shadow-md shadow-green-500/20"
              aria-label="Confirmar turno"
            >
              ✓ Agendar Turno
            </button>
          </div>
        </form>
      </section>

      <!-- Success State -->
      <section id="step-success" class="scheduler-step hidden text-center py-8">
        <div
          class="w-16 h-16 bg-green-100 text-green-600 rounded-full flex items-center justify-center mx-auto mb-4"
          aria-hidden="true"
        >
          <svg
            class="w-10 h-10"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M5 13l4 4L19 7"></path>
          </svg>
        </div>

        <h3 class="text-xl font-bold mb-2 text-slate-800">¡Turno Agendado!</h3>
        <p class="text-slate-500 text-sm mb-6">
          Te contactaremos pronto para confirmar.
        </p>

        <button
          id="reset-scheduler"
          type="button"
          class="text-blue-600 text-sm font-medium hover:underline focus:outline-none"
        >
          Agendar otro turno
        </button>
      </section>
    </main>
  </div>
</div>

<script>
  // Types
  interface WorkType {
    id: number;
    name: string;
    description?: string;
    duration?: number;
  }

  interface AppState {
    currentStep: number;
    workTypes: WorkType[];
    selectedWorkType: WorkType | null;
    selectedDate: string | null;
    selectedTime: string | null;
    availableSlots: string[];
    isLoading: boolean;
  }

  // Mapeo de nombres de servicios a español
  const SERVICE_TRANSLATIONS: Record<string, string> = {
    "Residential Cleaning": "Limpieza Residencial",
    "Commercial Cleaning": "Limpieza Comercial",
    "Deep Cleaning": "Limpieza Profunda",
    "Post-Construction Cleaning": "Limpieza Post-Obra",
    "Leak Repairs": "Reparación de Fugas",
    "Pipe Installation": "Instalación de Tuberías",
    "Drain Unclogging": "Destape de Desagües",
    "Residential Construction": "Construcción Residencial",
    "Commercial Construction": "Construcción Comercial",
    "Remodeling and Additions": "Remodelación y Ampliaciones",
  };

  // Iconos por categoría de servicio
  const SERVICE_ICONS: Record<string, string> = {
    "Limpieza Residencial": "🏠",
    "Limpieza Comercial": "🏢",
    "Limpieza Profunda": "✨",
    "Limpieza Post-Obra": "🧹",
    "Reparación de Fugas": "💧",
    "Instalación de Tuberías": "🔧",
    "Destape de Desagües": "🚿",
    "Construcción Residencial": "🏗️",
    "Construcción Comercial": "🏛️",
    "Remodelación y Ampliaciones": "🔨",
  };

  // Helper para traducir
  function translateService(name: string): string {
    return SERVICE_TRANSLATIONS[name] || name;
  }

  function getServiceIcon(name: string): string {
    const translated = translateService(name);
    return SERVICE_ICONS[translated] || "📋";
  }

  // State Management
  class SchedulerState {
    private state: AppState = {
      currentStep: 1,
      workTypes: [],
      selectedWorkType: null,
      selectedDate: null,
      selectedTime: null,
      availableSlots: [],
      isLoading: false,
    };

    private listeners: Set<() => void> = new Set();

    getState(): Readonly<AppState> {
      return { ...this.state };
    }

    setState(updates: Partial<AppState>): void {
      this.state = { ...this.state, ...updates };
      this.notify();
    }

    subscribe(listener: () => void): () => void {
      this.listeners.add(listener);
      return () => this.listeners.delete(listener);
    }

    private notify(): void {
      this.listeners.forEach((listener) => listener());
    }

    reset(): void {
      this.state = {
        currentStep: 1,
        workTypes: this.state.workTypes,
        selectedWorkType: null,
        selectedDate: null,
        selectedTime: null,
        availableSlots: [],
        isLoading: false,
      };
      this.notify();
    }
  }

  // Utils
  const utils = {
    formatDate(dateStr: string): string {
      const date = new Date(dateStr);
      const options: Intl.DateTimeFormatOptions = {
        weekday: "long",
        day: "numeric",
        month: "long",
      };
      return date.toLocaleDateString("es-AR", options);
    },

    validatePhone(phone: string): boolean {
      const cleaned = phone.replace(/[\s\-\(\)]/g, "");
      return /^[\+]?[\d]{8,15}$/.test(cleaned);
    },

    validateName(name: string): boolean {
      return name.trim().length >= 3 && /^[a-zA-ZáéíóúÁÉÍÓÚñÑ\s]+$/.test(name);
    },

    createElement<K extends keyof HTMLElementTagNameMap>(
      tag: K,
      attributes?: Record<string, string>,
      classes?: string[],
    ): HTMLElementTagNameMap[K] {
      const element = document.createElement(tag);
      if (classes) element.classList.add(...classes);
      if (attributes) {
        Object.entries(attributes).forEach(([key, value]) => {
          element.setAttribute(key, value);
        });
      }
      return element;
    },

    clearElement(element: Element): void {
      while (element.firstChild) {
        element.removeChild(element.firstChild);
      }
    },
  };

  // DOM Factory - Diseño mejorado
  const DOMFactory = {
    createWorkTypeCard(
      workType: WorkType,
      onClick: () => void,
    ): HTMLButtonElement {
      const translatedName = translateService(workType.name);
      const icon = getServiceIcon(workType.name);

      const button = utils.createElement(
        "button",
        {
          type: "button",
          "data-id": workType.id.toString(),
          role: "radio",
          "aria-checked": "false",
        },
        [
          "w-full",
          "text-left",
          "px-4",
          "py-3",
          "border",
          "border-slate-200",
          "rounded-lg",
          "hover:border-blue-400",
          "hover:bg-blue-50/50",
          "transition-all",
          "duration-200",
          "flex",
          "items-center",
          "gap-3",
          "group",
          "cursor-pointer",
          "focus:outline-none",
          "focus:ring-2",
          "focus:ring-blue-500",
        ],
      );

      // Icon container
      const iconSpan = utils.createElement("span", {}, [
        "text-xl",
        "w-8",
        "h-8",
        "flex",
        "items-center",
        "justify-center",
        "bg-slate-100",
        "rounded-lg",
        "group-hover:bg-blue-100",
        "transition-colors",
      ]);
      iconSpan.textContent = icon;

      // Content
      const contentDiv = utils.createElement("div", {}, ["flex-1", "min-w-0"]);

      const title = utils.createElement("p", {}, [
        "font-medium",
        "text-slate-800",
        "text-sm",
        "truncate",
      ]);
      title.textContent = translatedName;
      contentDiv.appendChild(title);

      // Arrow
      const arrow = utils.createElement("span", {}, [
        "text-slate-300",
        "group-hover:text-blue-500",
        "transition-colors",
        "text-sm",
      ]);
      arrow.textContent = "→";

      button.appendChild(iconSpan);
      button.appendChild(contentDiv);
      button.appendChild(arrow);
      button.addEventListener("click", onClick);

      return button;
    },

    createDayCell(
      day: number,
      dateStr: string,
      isPast: boolean,
      isWeekend: boolean,
      onClick: () => void,
    ): HTMLDivElement {
      const cell = utils.createElement(
        "div",
        {
          "data-date": dateStr,
          ...(isPast ? {} : { role: "button", tabindex: "0" }),
        },
        [
          "w-8",
          "h-8",
          "flex",
          "items-center",
          "justify-center",
          "text-sm",
          "font-medium",
          "transition-all",
          "duration-150",
          "rounded-full",
          ...(isPast
            ? ["text-slate-300", "cursor-not-allowed"]
            : isWeekend
              ? ["text-slate-500", "hover:bg-blue-100", "cursor-pointer"]
              : ["text-slate-700", "hover:bg-blue-100", "cursor-pointer"]),
        ],
      );

      cell.textContent = day.toString();

      if (!isPast) {
        cell.addEventListener("click", onClick);
      }

      return cell;
    },

    createTimeSlot(time: string, onClick: () => void): HTMLButtonElement {
      const button = utils.createElement(
        "button",
        {
          type: "button",
          "data-time": time,
          role: "radio",
          "aria-checked": "false",
        },
        [
          "border",
          "border-slate-200",
          "rounded-lg",
          "py-2",
          "px-3",
          "text-sm",
          "font-medium",
          "hover:border-blue-400",
          "hover:bg-blue-50",
          "transition-all",
          "duration-150",
          "cursor-pointer",
          "focus:outline-none",
          "focus:ring-2",
          "focus:ring-blue-500",
        ],
      );

      button.textContent = time;
      button.addEventListener("click", onClick);

      return button;
    },

    createLoadingMessage(message: string): HTMLDivElement {
      const div = utils.createElement("div", {}, [
        "col-span-3",
        "text-center",
        "py-6",
      ]);
      div.innerHTML = `<span class="animate-pulse text-slate-400 text-sm">${message}</span>`;
      return div;
    },

    createEmptyMessage(): HTMLDivElement {
      const div = utils.createElement("div", {}, [
        "col-span-3",
        "text-center",
        "py-6",
      ]);
      div.innerHTML = `
        <span class="text-2xl">😔</span>
        <p class="text-sm text-slate-400 mt-2">No hay horarios disponibles</p>
      `;
      return div;
    },

    createSummaryItem(label: string, value: string): HTMLLIElement {
      const li = utils.createElement("li", {}, ["flex", "gap-2"]);
      li.innerHTML = `<strong class="text-blue-800">${label}:</strong> <span>${value}</span>`;
      return li;
    },
  };

  // API Service
  const api = {
    async fetchWorkTypes(): Promise<WorkType[]> {
      const response = await fetch("/api/work-types");
      if (!response.ok) throw new Error("Failed to fetch work types");
      return response.json();
    },

    async fetchSlots(date: string, workTypeId: number): Promise<string[]> {
      const response = await fetch(
        `/api/slots?date=${date}&workTypeId=${workTypeId}`,
      );
      if (!response.ok) throw new Error("Failed to fetch slots");
      return response.json();
    },

    async createVisit(data: {
      nombre: string;
      telefono: string;
      mensaje: string;
      date: string;
      time: string;
      workTypeId: number;
    }): Promise<void> {
      const response = await fetch("/api/visits", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });
      if (!response.ok) throw new Error("Failed to create visit");
    },
  };

  // Main App
  class VisitScheduler {
    private state: SchedulerState;
    private unsubscribe?: () => void;

    constructor() {
      this.state = new SchedulerState();
      this.init();
    }

    private async init(): Promise<void> {
      try {
        this.state.setState({ isLoading: true });
        const workTypes = await api.fetchWorkTypes();
        this.state.setState({ workTypes, isLoading: false });
        this.renderWorkTypes();
      } catch (error) {
        console.error("Error loading work types:", error);
        this.showError("No se pudieron cargar los servicios");
        this.state.setState({ isLoading: false });
      }

      this.setupEventListeners();
      this.unsubscribe = this.state.subscribe(() => this.render());
    }

    private setupEventListeners(): void {
      document.getElementById("next-1")?.addEventListener("click", () => {
        this.goToStep(2);
        this.renderCalendar();
      });

      document
        .getElementById("back-2")
        ?.addEventListener("click", () => this.goToStep(1));

      document.getElementById("next-2")?.addEventListener("click", () => {
        const { selectedWorkType, selectedDate, selectedTime } = this.state.getState();
        if (!selectedWorkType || !selectedDate || !selectedTime) return;

        // Save selection to sessionStorage and redirect to checkout
        sessionStorage.setItem("checkout", JSON.stringify({
          workTypeId: selectedWorkType.id,
          workTypeName: selectedWorkType.name,
          workTypeDuration: selectedWorkType.duration,
          date: selectedDate,
          time: selectedTime,
        }));

        window.location.href = "/checkout";
      });

      document
        .getElementById("reset-scheduler")
        ?.addEventListener("click", () => this.reset());
    }

    private renderWorkTypes(): void {
      const grid = document.getElementById("work-types-grid");
      if (!grid) return;

      const { workTypes } = this.state.getState();

      utils.clearElement(grid);

      if (workTypes.length === 0) {
        const message = utils.createElement("p", {}, [
          "text-center",
          "text-slate-500",
          "py-8",
        ]);
        message.textContent = "No hay servicios disponibles.";
        grid.appendChild(message);
        return;
      }

      const fragment = document.createDocumentFragment();

      workTypes.forEach((wt) => {
        const card = DOMFactory.createWorkTypeCard(wt, () =>
          this.selectWorkType(wt.id),
        );
        fragment.appendChild(card);
      });

      grid.appendChild(fragment);
    }

    private selectWorkType(id: number): void {
      const { workTypes } = this.state.getState();
      const selected = workTypes.find((w) => w.id === id);

      if (!selected) return;

      this.state.setState({ selectedWorkType: selected });

      document.querySelectorAll("button[data-id]").forEach((btn) => {
        const isSelected = btn.getAttribute("data-id") === id.toString();
        if (isSelected) {
          btn.classList.add("border-blue-500", "bg-blue-50");
        } else {
          btn.classList.remove("border-blue-500", "bg-blue-50");
        }
        btn.setAttribute("aria-checked", isSelected.toString());
      });

      const nextBtn = document.getElementById("next-1") as HTMLButtonElement;
      if (nextBtn) nextBtn.disabled = false;
    }

    private renderCalendar(): void {
      const container = document.getElementById("calendar-container");
      if (!container) return;

      utils.clearElement(container);

      const today = new Date();
      const currentMonth = today.getMonth();
      const currentYear = today.getFullYear();

      const monthNames = [
        "Enero",
        "Febrero",
        "Marzo",
        "Abril",
        "Mayo",
        "Junio",
        "Julio",
        "Agosto",
        "Septiembre",
        "Octubre",
        "Noviembre",
        "Diciembre",
      ];

      // Header
      const header = utils.createElement("div", {}, [
        "text-center",
        "font-bold",
        "mb-3",
        "text-slate-800",
        "text-sm",
      ]);
      header.textContent = `${monthNames[currentMonth]} ${currentYear}`;
      container.appendChild(header);

      // Week days
      const weekDays = utils.createElement("div", {}, [
        "grid",
        "grid-cols-7",
        "gap-1",
        "text-center",
        "text-xs",
        "font-medium",
        "text-slate-400",
        "mb-2",
      ]);
      ["Do", "Lu", "Ma", "Mi", "Ju", "Vi", "Sa"].forEach((day) => {
        const dayDiv = utils.createElement("div");
        dayDiv.textContent = day;
        weekDays.appendChild(dayDiv);
      });
      container.appendChild(weekDays);

      // Days grid
      const daysGrid = utils.createElement("div", {}, [
        "grid",
        "grid-cols-7",
        "gap-1",
        "place-items-center",
      ]);

      const firstDay = new Date(currentYear, currentMonth, 1).getDay();
      const daysInMonth = new Date(currentYear, currentMonth + 1, 0).getDate();

      // Empty cells
      for (let i = 0; i < firstDay; i++) {
        daysGrid.appendChild(utils.createElement("div"));
      }

      // Day cells
      const todayDate = new Date();
      todayDate.setHours(0, 0, 0, 0);

      const fragment = document.createDocumentFragment();

      for (let day = 1; day <= daysInMonth; day++) {
        const date = new Date(currentYear, currentMonth, day);
        const isPast = date < todayDate;
        const isWeekend = date.getDay() === 0 || date.getDay() === 6;
        const dateStr = `${currentYear}-${String(currentMonth + 1).padStart(2, "0")}-${String(day).padStart(2, "0")}`;

        const cell = DOMFactory.createDayCell(
          day,
          dateStr,
          isPast,
          isWeekend,
          () => this.selectDate(dateStr),
        );
        fragment.appendChild(cell);
      }

      daysGrid.appendChild(fragment);
      container.appendChild(daysGrid);
    }

    private async selectDate(date: string): Promise<void> {
      this.state.setState({ selectedDate: date, selectedTime: null });

      document.querySelectorAll("div[data-date]").forEach((cell) => {
        const isSelected = cell.getAttribute("data-date") === date;
        if (isSelected) {
          cell.classList.add("bg-blue-600", "text-white");
          cell.classList.remove("hover:bg-blue-100");
        } else {
          cell.classList.remove("bg-blue-600", "text-white");
          if (!cell.classList.contains("text-slate-300")) {
            cell.classList.add("hover:bg-blue-100");
          }
        }
      });

      const { selectedWorkType } = this.state.getState();
      if (!selectedWorkType) return;

      const slotsGrid = document.getElementById("slots-grid");
      if (!slotsGrid) return;

      utils.clearElement(slotsGrid);
      slotsGrid.appendChild(DOMFactory.createLoadingMessage("Cargando..."));

      try {
        const slots = await api.fetchSlots(date, selectedWorkType.id);
        this.state.setState({ availableSlots: slots });
        this.renderSlots(slots);
      } catch (error) {
        console.error("Error fetching slots:", error);
        utils.clearElement(slotsGrid);
        slotsGrid.appendChild(DOMFactory.createEmptyMessage());
      }
    }

    private renderSlots(slots: string[]): void {
      const grid = document.getElementById("slots-grid");
      if (!grid) return;

      utils.clearElement(grid);

      if (slots.length === 0) {
        grid.appendChild(DOMFactory.createEmptyMessage());
        return;
      }

      const fragment = document.createDocumentFragment();

      slots.forEach((time) => {
        const slot = DOMFactory.createTimeSlot(time, () =>
          this.selectTime(time),
        );
        fragment.appendChild(slot);
      });

      grid.appendChild(fragment);
    }

    private selectTime(time: string): void {
      this.state.setState({ selectedTime: time });

      document.querySelectorAll("button[data-time]").forEach((btn) => {
        const isSelected = btn.getAttribute("data-time") === time;
        if (isSelected) {
          btn.classList.add("bg-blue-600", "text-white", "border-blue-600");
          btn.classList.remove("hover:bg-blue-50");
        } else {
          btn.classList.remove("bg-blue-600", "text-white", "border-blue-600");
          btn.classList.add("hover:bg-blue-50");
        }
        btn.setAttribute("aria-checked", isSelected.toString());
      });

      const nextBtn = document.getElementById("next-2") as HTMLButtonElement;
      if (nextBtn) nextBtn.disabled = false;
    }

    private updateSummary(): void {
      const list = document.getElementById("summary-list");
      if (!list) return;

      const { selectedWorkType, selectedDate, selectedTime } =
        this.state.getState();

      if (!selectedWorkType || !selectedDate || !selectedTime) return;

      utils.clearElement(list);

      const fragment = document.createDocumentFragment();

      fragment.appendChild(
        DOMFactory.createSummaryItem(
          "Servicio",
          translateService(selectedWorkType.name),
        ),
      );
      fragment.appendChild(
        DOMFactory.createSummaryItem("Fecha", utils.formatDate(selectedDate)),
      );
      fragment.appendChild(DOMFactory.createSummaryItem("Hora", selectedTime));

      list.appendChild(fragment);
    }

    private validateField(input: HTMLInputElement): boolean {
      const errorSpan = input.parentElement?.querySelector(".error-message");
      let isValid = true;
      let errorMessage = "";

      if (input.name === "nombre") {
        isValid = utils.validateName(input.value);
        errorMessage = "Nombre inválido (mínimo 3 letras)";
      } else if (input.name === "telefono") {
        isValid = utils.validatePhone(input.value);
        errorMessage = "Teléfono inválido";
      }

      if (!isValid) {
        input.classList.add("border-red-300");
        input.classList.remove("border-slate-200");
      } else {
        input.classList.remove("border-red-300");
        input.classList.add("border-slate-200");
      }

      if (errorSpan) {
        errorSpan.textContent = isValid ? "" : errorMessage;
        errorSpan.classList.toggle("hidden", isValid);
      }

      return isValid;
    }

    private async handleSubmit(e: Event): Promise<void> {
      e.preventDefault();

      const form = e.target as HTMLFormElement;
      const formData = new FormData(form);

      const nameInput = form.querySelector(
        '[name="nombre"]',
      ) as HTMLInputElement;
      const phoneInput = form.querySelector(
        '[name="telefono"]',
      ) as HTMLInputElement;

      const isNameValid = this.validateField(nameInput);
      const isPhoneValid = this.validateField(phoneInput);

      if (!isNameValid || !isPhoneValid) return;

      const { selectedDate, selectedTime, selectedWorkType } =
        this.state.getState();

      if (!selectedDate || !selectedTime || !selectedWorkType) {
        alert("Por favor completa todos los pasos");
        return;
      }

      const submitBtn = form.querySelector(
        'button[type="submit"]',
      ) as HTMLButtonElement;
      const originalText = submitBtn.textContent;

      submitBtn.disabled = true;
      submitBtn.textContent = "Enviando...";

      try {
        await api.createVisit({
          nombre: formData.get("nombre") as string,
          telefono: formData.get("telefono") as string,
          mensaje: formData.get("mensaje") as string,
          date: selectedDate,
          time: selectedTime,
          workTypeId: selectedWorkType.id,
        });

        this.goToStep("success");
      } catch (error) {
        console.error("Error creating visit:", error);

        const errorMessage =
          error instanceof Error ? error.message : String(error);
        const isSlotTaken =
          errorMessage.includes("horario ya está ocupado") ||
          errorMessage.includes("Slot already taken") ||
          errorMessage.includes("Este horario ya está ocupado");

        if (isSlotTaken) {
          alert(
            "Este horario acaba de ser reservado. Por favor selecciona otro.",
          );
          this.goToStep(2);

          if (selectedDate && selectedWorkType) {
            try {
              const slots = await api.fetchSlots(
                selectedDate,
                selectedWorkType.id,
              );
              this.state.setState({
                availableSlots: slots,
                selectedTime: null,
              });
              this.renderSlots(slots);
            } catch (refreshError) {
              console.error("Error refreshing slots:", refreshError);
            }
          }
        } else {
          alert("Error al agendar. Intenta de nuevo.");
          submitBtn.disabled = false;
          submitBtn.textContent = originalText || "Agendar Turno";
        }
      }
    }

    private goToStep(step: number | string): void {
      document.querySelectorAll(".scheduler-step").forEach((s) => {
        s.classList.add("hidden");
      });

      document.getElementById(`step-${step}`)?.classList.remove("hidden");

      if (typeof step === "number") {
        this.state.setState({ currentStep: step });
        this.updateStepIndicators(step);
      }
    }

    private updateStepIndicators(currentStep: number): void {
      document.querySelectorAll(".step-indicator").forEach((indicator) => {
        const step = parseInt(indicator.getAttribute("data-step") || "0");
        const badge = indicator.querySelector(".step-badge") as HTMLElement;

        if (!badge) return;

        indicator.classList.remove("active");
        badge.classList.remove(
          "bg-blue-500",
          "border-blue-500",
          "bg-green-500",
          "border-green-500",
          "text-slate-400",
          "border-slate-600",
        );

        if (step < currentStep) {
          badge.classList.add("bg-green-500", "border-green-500", "text-white");
          utils.clearElement(badge);
          badge.innerHTML = `<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>`;
        } else if (step === currentStep) {
          indicator.classList.add("active");
          badge.classList.add("bg-blue-500", "border-blue-500", "text-white");
          badge.textContent = step.toString();
        } else {
          badge.classList.add("border-slate-600", "text-slate-400");
          badge.textContent = step.toString();
        }
      });
    }

    private showError(message: string): void {
      const grid = document.getElementById("work-types-grid");
      if (!grid) return;

      utils.clearElement(grid);

      const wrapper = utils.createElement("div", {}, ["text-center", "py-8"]);
      wrapper.innerHTML = `
        <p class="text-red-500 mb-4">${message}</p>
        <button type="button" class="text-blue-600 hover:underline text-sm" onclick="location.reload()">
          Reintentar
        </button>
      `;
      grid.appendChild(wrapper);
    }

    private reset(): void {
      this.state.reset();
      this.goToStep(1);
      this.renderWorkTypes();

      const form = document.getElementById("booking-form") as HTMLFormElement;
      form?.reset();

      document.querySelectorAll("button[data-id]").forEach((btn) => {
        btn.classList.remove("border-blue-500", "bg-blue-50");
        btn.setAttribute("aria-checked", "false");
      });

      (document.getElementById("next-1") as HTMLButtonElement).disabled = true;
      (document.getElementById("next-2") as HTMLButtonElement).disabled = true;
    }

    private render(): void {}

    destroy(): void {
      this.unsubscribe?.();
    }
  }

  // Initialize
  let scheduler: VisitScheduler;

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", () => {
      scheduler = new VisitScheduler();
    });
  } else {
    scheduler = new VisitScheduler();
  }

  document.addEventListener("astro:before-swap", () => {
    scheduler?.destroy();
  });
</script>
