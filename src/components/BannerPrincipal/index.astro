---
import Button from "../Button/index.astro";
import RoomImg from "../../assets/room.jpg";
---

<section
  data-parallax
  class="relative w-full h-screen min-h-[600px] overflow-hidden"
>
  <!-- Worker (parallax) -->
  <picture
    id="parallax-worker"
    class="absolute top-0 right-0 w-[500px] lg:w-[600px] z-20 pointer-events-none"
    style="will-change: transform;"
  >
    <img
      src="https://png.pngtree.com/png-vector/20240908/ourmid/pngtree-professional-cleaner-with-mop-and-gloves-png-image_13791940.png"
      alt="Professional cleaner"
      class="w-full h-auto drop-shadow-2xl"
    />
  </picture>

  <!-- Background with overlay -->
  <div class="absolute inset-0 z-0">
    <picture class="absolute w-full h-full">
      <img
        class="w-full h-full object-cover"
        src={RoomImg.src}
        alt="Clean room background"
      />
    </picture>
    <!-- Dark overlay for better text readability -->
    <div
      class="absolute inset-0 bg-gradient-to-r from-black/70 via-black/50 to-transparent"
    >
    </div>
    <!-- Bottom gradient with sky color -->
    <div
      class="absolute bottom-0 left-0 w-full h-2/3 bg-gradient-to-t from-sky-700/60 via-sky-700/20 to-transparent"
    >
    </div>
  </div>

  <!-- Content -->
  <article
    class="relative z-30 container mx-auto px-6 lg:px-10 h-full flex items-center"
  >
    <div class="max-w-2xl space-y-6 lg:space-y-8 py-20">
      <!-- Badge -->
      <div
        class="inline-flex items-center gap-2 bg-sky-500/20 backdrop-blur-sm border border-sky-400/30 rounded-full px-4 py-2"
      >
        <span class="w-2 h-2 bg-sky-400 rounded-full animate-pulse"></span>
        <span class="text-sky-100 text-sm font-medium tracking-wide"
          >Servicios Profesionales</span
        >
      </div>

      <!-- Main heading -->
      <h1
        class="text-5xl md:text-6xl lg:text-7xl font-bold text-white leading-tight"
      >
        Professional Services
        <span class="block text-sky-300 mt-2">for your home</span>
      </h1>

      <!-- Description -->
      <p class="text-xl md:text-2xl text-gray-100 leading-relaxed max-w-xl">
        Limpieza, construcción y carpintería de confianza para hogares y
        empresas.
      </p>

      <!-- CTA Buttons -->
      <div
        class="flex flex-col sm:flex-row items-start sm:items-center gap-4 pt-4"
      >
        <Button text="Ask for a quote" />
        <a
          href="#services"
          class="group flex items-center gap-2 text-white text-lg font-medium hover:text-sky-300 transition-colors duration-300"
        >
          <span>All Services</span>
          <svg
            class="w-5 h-5 transform group-hover:translate-x-1 transition-transform duration-300"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>

      <!-- Trust indicators -->
      <div class="flex items-center gap-8 pt-6 text-gray-200">
        <div class="flex items-center gap-2">
          <svg
            class="w-5 h-5 text-sky-400"
            fill="currentColor"
            viewBox="0 0 20 20"
          >
            <path
              d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
            ></path>
          </svg>
          <span class="text-sm font-medium">5.0 Rating</span>
        </div>
        <div class="flex items-center gap-2">
          <svg
            class="w-5 h-5 text-sky-400"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <span class="text-sm font-medium">Servicio Garantizado</span>
        </div>
      </div>
    </div>
  </article>
</section>

<style>
  @keyframes float {
    0%,
    100% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-10px);
    }
  }

  #parallax-worker {
    animation: float 6s ease-in-out infinite;
  }

  /* Smooth transitions */
  section {
    transition: all 0.3s ease;
  }
</style>
