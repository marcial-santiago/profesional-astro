---
import { SERVICE_DATA } from "../../consts";
---

<section
  class="flex flex-col items-center justify-center mx-10 gap-5 my-[50px] min-h-[700px]"
>
  <h2 class="w-full text-[40px] font-bold m-0">Nuestros Servicios</h2>
  <main class="flex flex-row gap-5">
    {
      SERVICE_DATA.services.map((service) => (
        <article class="min-h-[400px] w-full bg-white flex flex-col items-center gap-5 rounded-2xl  overflow-hidden shadow-xl">
          <div class="relative flex flex-col items-center justify-center h-[66%]  w-full">
            <img
              src={service.urlImage}
              alt=""
              class="w-full h-full object-cover"
            />
            <div class="absolute w-full h-full bg-black/80 " />
            <h3 class="absolute text-2xl font-bold text-white">
              {service.sectionTitle}
            </h3>
          </div>
          <div class="flex flex-col gap-5 w-full h-full items-start justify-center p-10 ">
            <p class="text-black text-3xl">{service.sectionSubtitle}</p>
            <a
              href={`/services/${service.nameUrl}`}
              class="text-gray-500 text-sm"
            >
              Mas informacion →
            </a>
          </div>
        </article>
      ))
    }
  </main>
</section>
