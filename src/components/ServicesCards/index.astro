---
interface Props {
  grouped: Record<string, Array<{
    id: number;
    name: string;
    slug: string;
    description: string | null;
    image: { path: string } | null;
    category: string;
    duration: number;
    price: number;
    isActive: boolean;
  }>>;
}

const { grouped } = Astro.props;
const categories = Object.entries(grouped);

const categoryIcons: Record<string, string> = {
  cleaning: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 22l4-4"/><path d="M7.5 13.5 15 6l3 3-7.5 7.5"/><path d="M15 6 9 2 7 4l4 4"/><path d="M21 12c0 4.97-4.03 9-9 9"/></svg>`,
  plumbing: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v6"/><path d="M12 22v-6"/><path d="M4.93 4.93l4.24 4.24"/><path d="M14.83 14.83l4.24 4.24"/><path d="M2 12h6"/><path d="M22 12h-6"/><path d="M4.93 19.07l4.24-4.24"/><path d="M14.83 9.17l4.24-4.24"/></svg>`,
  construction: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="20" height="12" rx="2"/><path d="M12 12h.01"/><path d="M17 12h.01"/><path d="M7 12h.01"/></svg>`,
};

const categoryLabels: Record<string, string> = {
  cleaning: "Cleaning",
  plumbing: "Plumbing",
  construction: "Construction",
};
---

<section class="bg-slate-50 py-24 px-6">
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-14">
      <div>
        <p class="text-sky-600 font-semibold text-sm uppercase tracking-widest mb-2">What We Do</p>
        <h2 class="text-4xl md:text-5xl font-bold text-slate-900 leading-tight">
          Our Services
        </h2>
      </div>
      <p class="text-slate-500 max-w-sm text-base leading-relaxed">
        Professional solutions for homes and businesses across Brisbane and surrounding areas.
      </p>
    </div>

    <!-- Category cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {categories.map(([category, services]) => {
        const firstWithImage = services.find(s => s.image?.path);
        const heroImage = firstWithImage?.image?.path || "";
        const icon = categoryIcons[category] || categoryIcons.cleaning;
        const label = categoryLabels[category] || category;

        return (
          <article class="group relative bg-white rounded-2xl overflow-hidden shadow-sm border border-slate-200 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
            <!-- Image -->
            <div class="relative h-56 overflow-hidden">
              {heroImage ? (
                <img
                  src={heroImage}
                  alt={label}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
              ) : (
                <div class="w-full h-full bg-gradient-to-br from-slate-600 to-slate-800" />
              )}
              <div class="absolute inset-0 bg-linear-to-t from-slate-900/80 via-slate-900/20 to-transparent"></div>

              <!-- Icon badge -->
              <div class="absolute top-4 left-4 w-12 h-12 bg-sky-500 rounded-xl flex items-center justify-center text-white shadow-lg">
                <Fragment set:html={icon} />
              </div>
            </div>

            <!-- Content -->
            <div class="p-6">
              <h3 class="text-xl font-bold text-slate-900 mb-2">
                {label} Services
              </h3>
              <p class="text-slate-500 text-sm leading-relaxed mb-5">
                {services.length} service{services.length !== 1 ? 's' : ''} available
              </p>

              <!-- Items preview -->
              <ul class="flex flex-col gap-1.5 mb-6">
                {services.slice(0, 3).map((item) => (
                  <li class="flex items-center gap-2 text-slate-600 text-sm">
                    <span class="w-1.5 h-1.5 bg-sky-500 rounded-full shrink-0"></span>
                    {item.name}
                  </li>
                ))}
              </ul>

              <a
                href={`/services/cat/${category}`}
                class="inline-flex items-center gap-2 text-sky-600 font-semibold text-sm hover:gap-3 transition-all duration-200"
              >
                View all services
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
          </article>
        );
      })}
    </div>

    {categories.length === 0 && (
      <div class="text-center py-12">
        <p class="text-xl text-slate-400">No services available yet.</p>
      </div>
    )}
  </div>
</section>
