---
import { SERVICE_DATA } from "../../consts";
---

<section class="relative py-20 lg:py-32 px-6 lg:px-10 bg-gradient-to-b from-sky-700 via-sky-400 to-sky-50 overflow-hidden">
  <!-- Decorative elements -->
  <div class="absolute top-0 left-0 w-full h-full opacity-10 pointer-events-none">
    <div class="absolute top-20 left-10 w-72 h-72 bg-white rounded-full blur-3xl"></div>
    <div class="absolute bottom-20 right-10 w-96 h-96 bg-white rounded-full blur-3xl"></div>
  </div>

  <div class="relative z-10 container mx-auto max-w-7xl">
    <!-- Header Section -->
    <header class="mb-16 lg:mb-20 text-center">
      <div class="inline-flex items-center gap-2 bg-white/20 backdrop-blur-sm border border-white/30 rounded-full px-5 py-2 mb-6">
        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
        <span class="text-white text-sm font-medium tracking-wide">What we offer</span>
      </div>
      
      <h2 class="text-5xl md:text-6xl lg:text-7xl font-bold text-white mb-4">
        Our Services
      </h2>
      <p class="text-xl md:text-2xl text-white/90 max-w-2xl mx-auto">
        Professional solutions tailored to your needs
      </p>
    </header>

    <!-- Services Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {SERVICE_DATA.services.map((service, index) => (
        <article 
          class="group relative bg-white rounded-3xl overflow-hidden shadow-2xl hover:shadow-sky-500/20 transition-all duration-500 hover:-translate-y-2 flex flex-col h-full"
          style={`animation: fadeInUp 0.6s ease-out ${index * 0.1}s both;`}
        >
          <!-- Image Container -->
          <div class="relative h-64 overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent z-10"></div>
            <img
              src={service.urlImage}
              alt={service.sectionTitle}
              class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-700"
            />
            
            <!-- Service Icon/Badge -->
            <div class="absolute top-4 right-4 z-20 bg-sky-500 text-white p-3 rounded-full shadow-lg">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                {service.nameUrl === 'cleaning' && (
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                )}
                {service.nameUrl === 'plumbing' && (
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/>
                )}
                {service.nameUrl === 'construction' && (
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                )}
              </svg>
            </div>

            <!-- Title Overlay -->
            <h3 class="absolute bottom-6 left-6 right-6 z-20 text-3xl font-bold text-white leading-tight">
              {service.sectionTitle}
            </h3>
          </div>

          <!-- Content Container -->
          <div class="flex flex-col flex-grow p-6 lg:p-8">
            <!-- Description -->
            <p class="text-gray-700 text-lg leading-relaxed mb-6 flex-grow">
              {service.sectionSubtitle}
            </p>

            <!-- Features List (optional enhancement) -->
            <div class="mb-6 space-y-2">
              {service.items.slice(0, 3).map((item) => (
                <div class="flex items-center gap-2 text-sm text-gray-600">
                  <svg class="w-4 h-4 text-sky-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                  </svg>
                  <span>{item.title}</span>
                </div>
              ))}
            </div>

            <!-- CTA Button -->
            <a
              href={`/services/${service.nameUrl}`}
              class="group/btn inline-flex items-center justify-between w-full bg-sky-500 hover:bg-sky-600 text-white font-semibold px-6 py-4 rounded-xl transition-all duration-300 shadow-lg hover:shadow-sky-500/50"
            >
              <span class="text-lg">See more details</span>
              <svg 
                class="w-5 h-5 transform group-hover/btn:translate-x-1 transition-transform duration-300" 
                fill="none" 
                stroke="currentColor" 
                viewBox="0 0 24 24"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
          </div>

          <div class="absolute inset-0 border-2 border-transparent group-hover:border-sky-500/50 rounded-3xl transition-all duration-500 pointer-events-none"></div>
        </article>
      ))}
    </div>

    <!-- Bottom CTA Section -->
    <div class="mt-20 text-center">
      <div class="bg-black/80 backdrop-blur-md border border-white/20 rounded-2xl p-8 lg:p-12 inline-block">
        <h3 class="text-3xl font-bold text-white mb-4">
          ¿No encuentras lo que buscas?
        </h3>
        <p class="text-white/90 text-lg mb-6 max-w-2xl">
          Contáctanos y cuéntanos sobre tu proyecto. Ofrecemos soluciones personalizadas.
        </p>
        <a 
          href="/contact" 
          class="inline-flex items-center gap-2 bg-white text-sky-600 font-bold px-8 py-4 rounded-xl hover:bg-sky-50 transition-all duration-300 shadow-xl hover:shadow-2xl"
        >
          <span>Contact us</span>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Smooth scroll behavior */
  html {
    scroll-behavior: smooth;
  }
</style>