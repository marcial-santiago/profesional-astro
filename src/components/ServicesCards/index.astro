---
import { SERVICE_DATA } from "../../consts";

// Iconos personalizados para cada servicio
const serviceIcons = {
  cleaning: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>`,
  plumbing: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/>`,
  construction: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>`,
};
---

<section class="relative py-20 lg:py-32 overflow-hidden bg-gradient-to-b from-gray-50 via-white to-sky-50">
  <!-- Animated Background Pattern -->
  <div class="absolute inset-0 opacity-[0.03] pointer-events-none">
    <div class="absolute inset-0" style="background-image: radial-gradient(circle at 2px 2px, rgb(14 165 233) 1px, transparent 0); background-size: 40px 40px;"></div>
  </div>

  <!-- Floating Elements -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-20 -left-20 w-72 h-72 bg-sky-300 rounded-full mix-blend-multiply filter blur-3xl opacity-20 animate-blob"></div>
    <div class="absolute top-40 -right-20 w-72 h-72 bg-sky-500 rounded-full mix-blend-multiply filter blur-3xl opacity-20 animate-blob animation-delay-2000"></div>
    <div class="absolute -bottom-20 left-1/2 w-72 h-72 bg-sky-400 rounded-full mix-blend-multiply filter blur-3xl opacity-20 animate-blob animation-delay-4000"></div>
  </div>

  <div class="relative z-10 container mx-auto px-6 lg:px-10">
    <!-- Header Section with Modern Design -->
    <header class="text-center mb-20">
      <!-- Animated Badge -->
      <div class="inline-flex items-center gap-3 bg-gradient-to-r from-sky-500 to-sky-600 text-white rounded-full px-6 py-3 mb-8 shadow-lg shadow-sky-500/30 animate-fade-in">
        <span class="relative flex h-3 w-3">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-white opacity-75"></span>
          <span class="relative inline-flex rounded-full h-3 w-3 bg-white"></span>
        </span>
        <span class="text-sm font-semibold tracking-wide uppercase">Premium Services</span>
      </div>
      
      <!-- Main Title with Gradient -->
      <h2 class="text-5xl md:text-6xl lg:text-7xl font-extrabold mb-6 animate-fade-in-up">
        <span class="bg-gradient-to-r from-gray-900 via-sky-800 to-sky-600 bg-clip-text text-transparent">
          Transform Your Space
        </span>
      </h2>
      
      <p class="text-xl md:text-2xl text-gray-600 max-w-3xl mx-auto leading-relaxed animate-fade-in-up animation-delay-200">
        Expert solutions crafted with precision and care. Choose excellence, choose us.
      </p>

      <!-- Decorative Line -->
      <div class="flex items-center justify-center gap-4 mt-10">
        <div class="h-px w-20 bg-gradient-to-r from-transparent to-sky-500"></div>
        <div class="w-2 h-2 rounded-full bg-sky-500"></div>
        <div class="h-px w-20 bg-gradient-to-l from-transparent to-sky-500"></div>
      </div>
    </header>

    <!-- Services Showcase with Alternating Layout -->
    <div class="space-y-24">
      {SERVICE_DATA.services.map((service, index) => {
        const isEven = index % 2 === 0;
        return (
          <article 
            class="group relative"
            style={`animation: slideIn${isEven ? 'Left' : 'Right'} 0.8s ease-out ${index * 0.2}s both;`}
          >
            <div class={`grid lg:grid-cols-2 gap-8 lg:gap-12 items-center ${!isEven ? 'lg:grid-flow-dense' : ''}`}>
              
              <!-- Image Side -->
              <div class={`relative ${!isEven ? 'lg:col-start-2' : ''}`}>
                <!-- Decorative Frame -->
                <div class="absolute -inset-4 bg-gradient-to-r from-sky-400 to-sky-600 rounded-3xl opacity-0 group-hover:opacity-20 blur-2xl transition-all duration-700"></div>
                
                <div class="relative rounded-3xl overflow-hidden shadow-2xl transform group-hover:scale-[1.02] transition-all duration-700">
                  <!-- Image -->
                  <div class="relative h-[400px] lg:h-[500px]">
                    <img
                      src={service.urlImage}
                      alt={service.sectionTitle}
                      class="w-full h-full object-cover"
                    />
                    <!-- Gradient Overlay -->
                    <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent"></div>
                    
                    <!-- Floating Badge -->
                    <div class="absolute top-6 right-6 bg-white/95 backdrop-blur-sm rounded-2xl px-4 py-3 shadow-xl transform group-hover:scale-110 transition-transform duration-500">
                      <div class="flex items-center gap-2">
                        <div class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></div>
                        <span class="text-sm font-bold text-gray-900">Available Now</span>
                      </div>
                    </div>

                    <!-- Service Number -->
                    <div class="absolute bottom-6 left-6 bg-sky-500 text-white font-black text-4xl w-16 h-16 rounded-2xl flex items-center justify-center shadow-2xl transform -rotate-12 group-hover:rotate-0 transition-transform duration-500">
                      {String(index + 1).padStart(2, '0')}
                    </div>
                  </div>
                </div>

                <!-- Decorative Elements -->
                <div class={`absolute -z-10 ${isEven ? '-right-8 top-8' : '-left-8 top-8'} w-32 h-32 bg-sky-200 rounded-full opacity-50 blur-2xl`}></div>
              </div>

              <!-- Content Side -->
              <div class={`space-y-6 ${!isEven ? 'lg:col-start-1 lg:row-start-1' : ''}`}>
                <!-- Icon -->
                <div class="inline-flex p-4 bg-gradient-to-br from-sky-500 to-sky-600 rounded-2xl shadow-lg shadow-sky-500/30 transform group-hover:scale-110 group-hover:rotate-3 transition-all duration-500">
                  <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <Fragment set:html={serviceIcons[service.nameUrl as keyof typeof serviceIcons]} />
                  </svg>
                </div>

                <!-- Title -->
                <h3 class="text-4xl lg:text-5xl font-bold text-gray-900 leading-tight group-hover:text-sky-600 transition-colors duration-300">
                  {service.sectionTitle}
                </h3>

                <!-- Description -->
                <p class="text-lg text-gray-600 leading-relaxed">
                  {service.sectionSubtitle}
                </p>

                <!-- Features Grid -->
                <div class="grid grid-cols-1 gap-3 pt-4">
                  {service.items.slice(0, 3).map((item, itemIndex) => (
                    <div 
                      class="flex items-start gap-3 bg-white rounded-xl p-4 shadow-md hover:shadow-lg transition-all duration-300 border border-gray-100 hover:border-sky-300 group/item"
                      style={`animation: fadeIn 0.5s ease-out ${itemIndex * 0.1 + 0.3}s both;`}
                    >
                      <div class="flex-shrink-0 w-6 h-6 bg-sky-100 rounded-lg flex items-center justify-center group-hover/item:bg-sky-500 transition-colors duration-300">
                        <svg class="w-4 h-4 text-sky-600 group-hover/item:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                        </svg>
                      </div>
                      <span class="text-gray-700 font-medium">{item.title}</span>
                    </div>
                  ))}
                </div>

                <!-- CTA Buttons -->
                <div class="flex flex-col sm:flex-row gap-4 pt-6">
                  <a
                    href={`/services/${service.nameUrl}`}
                    class="group/btn relative inline-flex items-center justify-center gap-3 bg-gradient-to-r from-sky-500 to-sky-600 hover:from-sky-600 hover:to-sky-700 text-white font-bold px-8 py-4 rounded-xl transition-all duration-300 shadow-lg shadow-sky-500/30 hover:shadow-xl hover:shadow-sky-500/40 overflow-hidden"
                  >
                    <span class="relative z-10">Explore Service</span>
                    <svg 
                      class="relative z-10 w-5 h-5 transform group-hover/btn:translate-x-1 transition-transform duration-300" 
                      fill="none" 
                      stroke="currentColor" 
                      viewBox="0 0 24 24"
                    >
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                    </svg>
                    <div class="absolute inset-0 bg-white/20 translate-y-full group-hover/btn:translate-y-0 transition-transform duration-300"></div>
                  </a>

                  
                  <a
                    href="#contact-form"
                    class="inline-flex items-center justify-center gap-3 bg-white hover:bg-gray-50 text-sky-600 font-bold px-8 py-4 rounded-xl border-2 border-sky-600 transition-all duration-300 shadow-md hover:shadow-lg"
                  >
                    <span>Get Quote</span>
                  </a>
                </div>
              </div>

            </div>
          </article>
        );
      })}
    </div>

    <!-- Bottom CTA Section - Redesigned -->
    <div class="mt-32">
      <div class="relative bg-gradient-to-br from-gray-900 via-sky-900 to-sky-800 rounded-3xl overflow-hidden shadow-2xl">
        <!-- Animated Background Pattern -->
        <div class="absolute inset-0 opacity-10">
          <div class="absolute inset-0" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 30px 30px;"></div>
        </div>

        <!-- Glow Effects -->
        <div class="absolute top-0 left-0 w-96 h-96 bg-sky-500 rounded-full blur-3xl opacity-20"></div>
        <div class="absolute bottom-0 right-0 w-96 h-96 bg-sky-400 rounded-full blur-3xl opacity-20"></div>

        <div class="relative z-10 text-center py-20 px-8 lg:px-20">
          <!-- Icon -->
          <div class="inline-flex p-6 bg-white/10 backdrop-blur-sm rounded-3xl mb-8 shadow-2xl">
            <svg class="w-16 h-16 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
            </svg>
          </div>

          <h3 class="text-4xl lg:text-5xl font-bold text-white mb-6">
            Can't Find What You Need?
          </h3>
          <p class="text-xl text-white/90 mb-10 max-w-2xl mx-auto leading-relaxed">
            We specialize in custom solutions. Share your vision with us and let's create something extraordinary together.
          </p>

          <!-- CTA Buttons -->
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <a 
              href="/contact" 
              class="group relative inline-flex items-center gap-3 bg-white text-gray-900 font-bold px-10 py-5 rounded-xl hover:bg-gray-100 transition-all duration-300 shadow-2xl hover:shadow-white/20 overflow-hidden"
            >
              <span class="relative z-10">Start a Conversation</span>
              <svg class="relative z-10 w-5 h-5 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>

            <a 
              href="tel:0466018580"
              class="inline-flex items-center gap-3 bg-white/10 backdrop-blur-sm hover:bg-white/20 text-white font-bold px-10 py-5 rounded-xl border-2 border-white/30 transition-all duration-300"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              <span>Call Us Directly</span>
            </a>
          </div>

          <!-- Trust Indicators -->
          <div class="flex flex-wrap items-center justify-center gap-8 mt-12 text-white/80">
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
              <span class="text-sm font-semibold">500+ Happy Clients</span>
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
              </svg>
              <span class="text-sm font-semibold">100% Satisfaction Guarantee</span>
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              <span class="text-sm font-semibold">24/7 Support</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Animations */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes slideInLeft {
    from {
      opacity: 0;
      transform: translateX(-50px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes slideInRight {
    from {
      opacity: 0;
      transform: translateX(50px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes blob {
    0%, 100% {
      transform: translate(0, 0) scale(1);
    }
    25% {
      transform: translate(20px, -20px) scale(1.1);
    }
    50% {
      transform: translate(-20px, 20px) scale(0.9);
    }
    75% {
      transform: translate(20px, 10px) scale(1.05);
    }
  }

  .animate-blob {
    animation: blob 10s infinite;
  }

  .animation-delay-2000 {
    animation-delay: 2s;
  }

  .animation-delay-4000 {
    animation-delay: 4s;
  }

  .animate-fade-in {
    animation: fade-in 0.8s ease-out;
  }

  .animate-fade-in-up {
    animation: fadeInUp 0.8s ease-out;
  }

  .animation-delay-200 {
    animation-delay: 0.2s;
    animation-fill-mode: both;
  }

  html {
    scroll-behavior: smooth;
  }
</style>