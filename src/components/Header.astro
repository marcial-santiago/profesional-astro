---
import HeaderLink from "./HeaderLink.astro";
import Button from "../components/Button/index.astro";
---

<header class="relative top-0 z-50 bg-white shadow-sm">
  <nav class="flex flex-row items-center px-10 py-4">
    <a href="/"><h2 class="text-2xl font-bold mr-8 text-blue-600">LOGO</h2></a>
    <div class="flex flex-row items-center gap-5">
      <HeaderLink href="/#inicio">Inicio</HeaderLink>
      <HeaderLink href="/#servicios">Servicios</HeaderLink>
      <HeaderLink href="/#nosotros">Nosotros</HeaderLink>
      <HeaderLink href="/#contacto">Contacto</HeaderLink>
    </div>
    <div class="ml-auto">
      <a href="/#contacto">
        <Button text="Solicitar presupuesto" />
      </a>
    </div>
  </nav>
</header>
