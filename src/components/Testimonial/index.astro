---
const testimonials = [
  {
    id: 1,
    name: "Sarah Mitchell",
    role: "Homeowner",
    image: "https://randomuser.me/api/portraits/women/32.jpg",
    rating: 5,
    text: "The cleaning service was absolutely exceptional! My home has never looked better. The team was professional, thorough, and paid attention to every detail. I'm beyond impressed!",
    service: "Residential Cleaning",
    date: "2 weeks ago",
    verified: true
  },
  {
    id: 2,
    name: "Michael Chen",
    role: "Business Owner",
    image: "https://randomuser.me/api/portraits/men/45.jpg",
    rating: 5,
    text: "Outstanding construction work! They transformed our office space completely. The project was completed on time and within budget. Highly professional team that I'd recommend to anyone.",
    service: "Commercial Construction",
    date: "1 month ago",
    verified: true
  },
  {
    id: 3,
    name: "Emily Rodriguez",
    role: "Property Manager",
    image: "https://randomuser.me/api/portraits/women/68.jpg",
    rating: 5,
    text: "I've worked with many service providers, but this team stands out. Their plumbing work was flawless, and they solved a complex issue that others couldn't. True professionals!",
    service: "Plumbing Services",
    date: "3 weeks ago",
    verified: true
  },
  {
    id: 4,
    name: "David Thompson",
    role: "Homeowner",
    image: "https://randomuser.me/api/portraits/men/22.jpg",
    rating: 5,
    text: "From start to finish, the experience was seamless. They handled our home renovation with incredible skill and care. The results exceeded our expectations. Worth every penny!",
    service: "Remodeling",
    date: "2 months ago",
    verified: true
  },
  {
    id: 5,
    name: "Jessica Parker",
    role: "Restaurant Owner",
    image: "https://randomuser.me/api/portraits/women/55.jpg",
    rating: 5,
    text: "Their deep cleaning service for our restaurant is top-notch. They're reliable, efficient, and always deliver excellent results. Our health inspection scores have never been better!",
    service: "Commercial Cleaning",
    date: "1 week ago",
    verified: true
  },
  {
    id: 6,
    name: "Robert Kim",
    role: "Real Estate Developer",
    image: "https://randomuser.me/api/portraits/men/67.jpg",
    rating: 5,
    text: "Working with this team on multiple properties has been a pleasure. Their construction quality is superior, and they always meet deadlines. A reliable partner for any project.",
    service: "Construction Services",
    date: "3 months ago",
    verified: true
  }
];
---

<section class="relative py-20 lg:py-32 bg-gradient-to-b from-sky-50 via-white to-sky-50 overflow-hidden">
  <!-- Decorative Background Elements -->
  <div class="absolute inset-0 opacity-5 pointer-events-none">
    <div class="absolute top-20 left-10 w-96 h-96 bg-sky-500 rounded-full blur-3xl animate-blob"></div>
    <div class="absolute top-40 right-10 w-72 h-72 bg-sky-700 rounded-full blur-3xl animate-blob animation-delay-2000"></div>
    <div class="absolute bottom-20 left-1/2 w-80 h-80 bg-sky-400 rounded-full blur-3xl animate-blob animation-delay-4000"></div>
  </div>

  <div class="relative z-10 container mx-auto px-6 lg:px-10">
    <!-- Section Header -->
    <header class="text-center mb-16 lg:mb-20">
      <div class="inline-flex items-center gap-2 bg-sky-100 border border-sky-200 rounded-full px-5 py-2 mb-6">
        <svg class="w-5 h-5 text-sky-600" fill="currentColor" viewBox="0 0 20 20">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
        </svg>
        <span class="text-sky-700 text-sm font-medium tracking-wide">Client Testimonials</span>
      </div>
      
      <h2 class="text-5xl md:text-6xl lg:text-7xl font-bold text-gray-900 mb-6">
        What Our Clients Say
      </h2>
      <p class="text-xl md:text-2xl text-gray-600 max-w-3xl mx-auto">
        Don't just take our word for it. Here's what our satisfied customers have to say about their experience.
      </p>

      <!-- Stats Bar -->
      <div class="flex flex-wrap items-center justify-center gap-8 lg:gap-12 mt-12">
        <div class="text-center">
          <div class="text-4xl lg:text-5xl font-bold text-sky-600 mb-2">500+</div>
          <div class="text-gray-600 text-sm lg:text-base">Happy Clients</div>
        </div>
        <div class="hidden md:block w-px h-12 bg-gray-300"></div>
        <div class="text-center">
          <div class="text-4xl lg:text-5xl font-bold text-sky-600 mb-2 flex items-center justify-center gap-2">
            5.0
            <svg class="w-8 h-8 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
          </div>
          <div class="text-gray-600 text-sm lg:text-base">Average Rating</div>
        </div>
        <div class="hidden md:block w-px h-12 bg-gray-300"></div>
        <div class="text-center">
          <div class="text-4xl lg:text-5xl font-bold text-sky-600 mb-2">98%</div>
          <div class="text-gray-600 text-sm lg:text-base">Satisfaction Rate</div>
        </div>
      </div>
    </header>

    <!-- Testimonials Grid with Bento Box Layout -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 auto-rows-auto">
      {testimonials.map((testimonial, index) => (
        <article 
          class={`group relative bg-white rounded-3xl p-8 shadow-xl hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 border border-gray-100 hover:border-sky-300 ${
            index === 0 ? 'md:col-span-2 lg:col-span-1' : ''
          } ${
            index === 3 ? 'lg:col-span-2' : ''
          }`}
          style={`animation: fadeInScale 0.6s ease-out ${index * 0.1}s both;`}
        >
          <!-- Quote Icon -->
          <div class="absolute top-6 right-6 opacity-10 group-hover:opacity-20 transition-opacity duration-500">
            <svg class="w-16 h-16 text-sky-600" fill="currentColor" viewBox="0 0 24 24">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
            </svg>
          </div>

          <!-- Header -->
          <div class="flex items-start justify-between mb-6">
            <div class="flex items-center gap-4">
              <!-- Avatar -->
              <div class="relative">
                <div class="absolute inset-0 bg-sky-500 rounded-full blur opacity-30 group-hover:opacity-50 transition-opacity"></div>
                <img 
                  src={testimonial.image} 
                  alt={testimonial.name}
                  class="relative w-16 h-16 rounded-full object-cover ring-4 ring-white shadow-lg"
                />
                {testimonial.verified && (
                  <div class="absolute -bottom-1 -right-1 bg-green-500 rounded-full p-1 ring-2 ring-white">
                    <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                    </svg>
                  </div>
                )}
              </div>

              <!-- Name & Role -->
              <div>
                <h3 class="font-bold text-gray-900 text-lg">{testimonial.name}</h3>
                <p class="text-sm text-gray-600">{testimonial.role}</p>
              </div>
            </div>
          </div>

          <!-- Rating -->
          <div class="flex items-center gap-1 mb-4">
            {Array.from({ length: 5 }).map((_, i) => (
              <svg 
                class={`w-5 h-5 ${i < testimonial.rating ? 'text-yellow-400' : 'text-gray-300'}`}
                fill="currentColor" 
                viewBox="0 0 20 20"
              >
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>

          <!-- Testimonial Text -->
          <p class="text-gray-700 leading-relaxed mb-6 text-lg">
            "{testimonial.text}"
          </p>

          <!-- Footer -->
          <div class="flex items-center justify-between pt-6 border-t border-gray-100">
            <div class="flex items-center gap-2">
              <span class="px-3 py-1 bg-sky-50 text-sky-700 text-sm font-medium rounded-full">
                {testimonial.service}
              </span>
            </div>
            <span class="text-sm text-gray-500">{testimonial.date}</span>
          </div>

          <!-- Hover Border Effect -->
          <div class="absolute inset-0 border-2 border-transparent group-hover:border-sky-500/30 rounded-3xl transition-all duration-500 pointer-events-none"></div>
        </article>
      ))}
    </div>

    <!-- CTA Section -->
    <div class="mt-20 text-center">
      <div class="bg-gradient-to-r from-sky-600 to-sky-700 rounded-3xl p-12 lg:p-16 shadow-2xl relative overflow-hidden">
        <!-- Decorative Elements -->
        <div class="absolute inset-0 opacity-10">
          <div class="absolute top-0 right-0 w-64 h-64 bg-white rounded-full blur-3xl"></div>
          <div class="absolute bottom-0 left-0 w-96 h-96 bg-white rounded-full blur-3xl"></div>
        </div>

        <div class="relative z-10">
          <h3 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-6">
            Ready to Join Our Happy Clients?
          </h3>
          <p class="text-xl text-white/90 mb-8 max-w-2xl mx-auto">
            Experience the quality service that our clients rave about. Get your free quote today!
          </p>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <a 
              href="/#contacto"
              class="inline-flex items-center gap-2 bg-white text-sky-700 font-bold px-8 py-4 rounded-xl hover:bg-sky-50 transition-all duration-300 shadow-xl hover:shadow-2xl hover:scale-105"
            >
              <span>Get Your Free Quote</span>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
            <a 
              href="tel:0466018580"
              class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border-2 border-white/30 text-white font-bold px-8 py-4 rounded-xl hover:bg-white/20 transition-all duration-300"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              <span>Call Us Now</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fadeInScale {
    from {
      opacity: 0;
      transform: scale(0.95) translateY(20px);
    }
    to {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }

  @keyframes blob {
    0%, 100% {
      transform: translate(0, 0) scale(1);
    }
    25% {
      transform: translate(20px, -20px) scale(1.1);
    }
    50% {
      transform: translate(-20px, 20px) scale(0.9);
    }
    75% {
      transform: translate(20px, 10px) scale(1.05);
    }
  }

  .animate-blob {
    animation: blob 10s infinite;
  }

  .animation-delay-2000 {
    animation-delay: 2s;
  }

  .animation-delay-4000 {
    animation-delay: 4s;
  }
</style>