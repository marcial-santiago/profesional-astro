---
const today = new Date();
---

<footer class="bg-gray-900 text-white pt-16 pb-8 mt-10">
  <div class="container mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-12">
      <!-- Sobre Nosotros -->
      <div>
        <h3 class="text-xl font-bold mb-6">Sobre Nosotros</h3>
        <p class="text-gray-400 leading-relaxed">
          Somos un equipo especializado en limpieza, servicio y carpinteria.
          Confiando en nuestro profecional servicio y de calidad.
        </p>
      </div>

      <!-- Enlaces -->
      <div>
        <h3 class="text-xl font-bold mb-6">Enlaces</h3>
        <ul class="flex flex-col gap-3">
          <li>
            <a href="/" class="text-gray-400 hover:text-white transition-colors"
              >Inicio</a
            >
          </li>
          <li>
            <a
              href="/servicios"
              class="text-gray-400 hover:text-white transition-colors"
              >Servicios</a
            >
          </li>
          <li>
            <a
              href="/#porque-elegirnos"
              class="text-gray-400 hover:text-white transition-colors"
              >Porque elegimos</a
            >
          </li>
          <li>
            <a
              href="/contacto"
              class="text-gray-400 hover:text-white transition-colors"
              >Contacto</a
            >
          </li>
        </ul>
      </div>

      <!-- Contacto -->
      <div>
        <h3 class="text-xl font-bold mb-6">Contacto</h3>
        <ul class="flex flex-col gap-3 text-gray-400">
          <li class="flex items-center gap-2">
            <span>(011) 1234-5678</span>
          </li>
          <li class="flex items-center gap-2">
            <span>Lunes a Sabado 6:00 - 18:00</span>
          </li>
          <li class="flex items-center gap-2">
            <span>info@tuempresa.com</span>
          </li>
          <li class="flex items-center gap-2">
            <span>Calle-falsa 123</span>
          </li>
          <li class="flex items-center gap-2">
            <span>Buenos aires, Argentina</span>
          </li>
        </ul>
      </div>

      <!-- Garantías y Acción -->
      <div>
        <h3 class="text-xl font-bold mb-6">Garantía</h3>
        <ul class="flex flex-col gap-3 mb-6 text-gray-400">
          <li class="flex items-center gap-2">
            <span class="text-green-500">✓</span> Presupuestos a medida
          </li>
          <li class="flex items-center gap-2">
            <span class="text-green-500">✓</span> Confianza asegurada
          </li>
          <li class="flex items-center gap-2">
            <span class="text-green-500">✓</span> Garantia de sactifacion
          </li>
        </ul>
        <a
          href="#presupuesto"
          class="inline-block bg-blue-600 text-white font-bold py-3 px-6 rounded-md hover:bg-blue-700 transition-colors w-full text-center"
        >
          Solicitar presupuesto
        </a>
      </div>
    </div>

    <div
      class="border-t border-gray-800 pt-8 mt-8 text-center text-gray-500 text-sm"
    >
      <p>
        &copy; {today.getFullYear()} Tu Empresa. Todos los derechos reservados.
      </p>
    </div>
  </div>
</footer>
