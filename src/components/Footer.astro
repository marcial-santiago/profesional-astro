---
const today = new Date();

const footerLinks = {
  quickLinks: [
    { href: "/", label: "Home" },
    { href: "/servicios", label: "Services" },
    { href: "/#porque-elegirnos", label: "Why Choose Us" },
    { href: "/contacto", label: "Contact Us" },
  ],
  contactInfo: [
    { icon: "phone", text: "0466 018 580", href: "tel:0466018580" },
    { icon: "clock", text: "Monday-Sunday 7:00-18:00" },
    {
      icon: "email",
      text: "crmmultiservises@hotmail.com",
      href: "mailto:crmmultiservises@hotmail.com",
    },
    { icon: "location", text: "6 Fielding Street, Mount Gravatt" },
    { icon: "location", text: "Brisbane-Australia" },
  ],
  guarantees: [
    "Customized Solutions",
    "Assured Quality",
    "Satisfaction Guaranteed",
  ],
};
---

<footer
  class="relative bg-gradient-to-b from-sky-700 to-sky-800 text-white overflow-hidden"
>
  <!-- Decorative Background Elements -->
  <div class="absolute inset-0 opacity-10 pointer-events-none">
    <div class="absolute top-0 left-0 w-96 h-96 bg-white rounded-full blur-3xl">
    </div>
    <div
      class="absolute bottom-0 right-0 w-72 h-72 bg-sky-400 rounded-full blur-3xl"
    >
    </div>
  </div>

  <div class="relative z-10">
    <!-- Main Footer Content -->
    <div class="container mx-auto px-6 lg:px-10 pt-20 pb-12">
      <div
        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-16"
      >
        <!-- About Section -->
        <div class="space-y-6">
          <div class="space-y-4">
            <div class="flex items-center gap-3">
              <div class="bg-white/20 p-2 rounded-lg">
                <svg
                  class="w-8 h-8 text-white"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"
                  ></path>
                </svg>
              </div>
              <h3 class="text-2xl font-bold">Roldans</h3>
            </div>
            <p class="text-white/90 leading-relaxed text-lg">
              We are dedicated to providing top-notch home services with a focus
              on quality, reliability, and customer satisfaction.
            </p>
          </div>

          <!-- Social Media -->
          <div class="flex gap-4 pt-2">
            <a
              href="#"
              class="bg-white/10 hover:bg-white/20 p-3 rounded-full transition-all duration-300 hover:scale-110"
              aria-label="Facebook"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path
                  d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
                ></path>
              </svg>
            </a>
            <a
              href="#"
              class="bg-white/10 hover:bg-white/20 p-3 rounded-full transition-all duration-300 hover:scale-110"
              aria-label="Instagram"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path
                  d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
                ></path>
              </svg>
            </a>
            <a
              href="#"
              class="bg-white/10 hover:bg-white/20 p-3 rounded-full transition-all duration-300 hover:scale-110"
              aria-label="WhatsApp"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path
                  d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"
                ></path>
              </svg>
            </a>
          </div>
        </div>

        <!-- Quick Links -->
        <div>
          <h3 class="text-xl font-bold mb-6 flex items-center gap-2">
            <svg
              class="w-5 h-5 text-sky-300"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
            Quick Links
          </h3>
          <ul class="space-y-3">
            {
              footerLinks.quickLinks.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="group flex items-center gap-2 text-white/80 hover:text-white transition-all duration-300"
                  >
                    <span class="w-0 group-hover:w-2 h-0.5 bg-sky-300 transition-all duration-300" />
                    <span class="group-hover:translate-x-1 transition-transform duration-300">
                      {link.label}
                    </span>
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <!-- Contact Info -->
        <div>
          <h3 class="text-xl font-bold mb-6 flex items-center gap-2">
            <svg
              class="w-5 h-5 text-sky-300"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path>
            </svg>
            Contact Info
          </h3>
          <ul class="space-y-4">
            {
              footerLinks.contactInfo.map((item) => (
                <li>
                  {item.href ? (
                    <a
                      href={item.href}
                      class="flex items-start gap-3 text-white/80 hover:text-white transition-colors duration-300 group"
                    >
                      {item.icon === "phone" && (
                        <svg
                          class="w-5 h-5 text-sky-300 flex-shrink-0 mt-0.5 group-hover:scale-110 transition-transform"
                          fill="none"
                          stroke="currentColor"
                          viewBox="0 0 24 24"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                          />
                        </svg>
                      )}
                      {item.icon === "email" && (
                        <svg
                          class="w-5 h-5 text-sky-300 flex-shrink-0 mt-0.5 group-hover:scale-110 transition-transform"
                          fill="none"
                          stroke="currentColor"
                          viewBox="0 0 24 24"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                          />
                        </svg>
                      )}
                      <span>{item.text}</span>
                    </a>
                  ) : (
                    <div class="flex items-start gap-3 text-white/80">
                      {item.icon === "clock" && (
                        <svg
                          class="w-5 h-5 text-sky-300 flex-shrink-0 mt-0.5"
                          fill="none"
                          stroke="currentColor"
                          viewBox="0 0 24 24"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                          />
                        </svg>
                      )}
                      {item.icon === "location" && (
                        <svg
                          class="w-5 h-5 text-sky-300 flex-shrink-0 mt-0.5"
                          fill="none"
                          stroke="currentColor"
                          viewBox="0 0 24 24"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                          />
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                          />
                        </svg>
                      )}
                      <span>{item.text}</span>
                    </div>
                  )}
                </li>
              ))
            }
          </ul>
        </div>

        <!-- Guarantees -->
        <div>
          <h3 class="text-xl font-bold mb-6 flex items-center gap-2">
            <svg
              class="w-5 h-5 text-sky-300"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
              ></path>
            </svg>
            Our Guarantee
          </h3>
          <ul class="space-y-4">
            {
              footerLinks.guarantees.map((guarantee) => (
                <li class="flex items-start gap-3 text-white/80">
                  <div class="bg-green-500 rounded-full p-1 flex-shrink-0 mt-0.5">
                    <svg
                      class="w-3 h-3 text-white"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="3"
                        d="M5 13l4 4L19 7"
                      />
                    </svg>
                  </div>
                  <span class="leading-relaxed">{guarantee}</span>
                </li>
              ))
            }
          </ul>

          <!-- CTA Button -->
          <div class="mt-8">
            <a
              href="/contacto"
              class="inline-flex items-center gap-2 bg-white text-sky-700 font-bold px-6 py-3 rounded-xl hover:bg-sky-50 transition-all duration-300 shadow-lg hover:shadow-xl hover:scale-105"
            >
              <span>Get Started</span>
              <svg
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-white/20">
      <div class="container mx-auto px-6 lg:px-10 py-8">
        <div
          class="flex flex-col md:flex-row items-center justify-between gap-4"
        >
          <!-- Copyright -->
          <p class="text-white/80 text-sm">
            &copy; {today.getFullYear()}
            <span class="font-semibold text-white">Roldans</span>. All rights
            reserved.
          </p>

          <!-- Legal Links -->
          <div class="flex items-center gap-6 text-sm">
            <a
              href="/privacy"
              class="text-white/80 hover:text-white transition-colors duration-300"
            >
              Privacy Policy
            </a>
            <span class="text-white/40">|</span>
            <a
              href="/terms"
              class="text-white/80 hover:text-white transition-colors duration-300"
            >
              Terms of Service
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>
