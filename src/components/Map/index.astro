---
const mapUrl = import.meta.env.GOOGLE_MAPS_EMBED_URL;
---

<div class="w-full h-96 bg-slate-100 relative" data-map-container>
  <noscript>
    <iframe
      src={mapUrl}
      width="100%"
      height="100%"
      style="border:0;"
      allowfullscreen
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
    ></iframe>
  </noscript>
  <div class="absolute inset-0 flex items-center justify-center text-slate-400 text-sm" data-map-placeholder>
    Loading map...
  </div>
</div>

<script define:vars={{ mapUrl }}>
  const container = document.querySelector("[data-map-container]");

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;

        const iframe = document.createElement("iframe");
        iframe.src = mapUrl;
        iframe.width = "100%";
        iframe.height = "100%";
        iframe.style.border = "0";
        iframe.allowFullscreen = true;
        iframe.loading = "lazy";
        iframe.referrerPolicy = "no-referrer-when-downgrade";

        const placeholder = container.querySelector("[data-map-placeholder]");
        if (placeholder) placeholder.remove();
        container.appendChild(iframe);

        observer.disconnect();
      });
    },
    { rootMargin: "200px" }
  );

  observer.observe(container);
</script>
