---
import Button from "../Button/index.astro";

const features = [
  {
    title: "Fast Response",
    desc: "Same-day and next-day availability. We show up on time, every time.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
  },
  {
    title: "Transparent Pricing",
    desc: "No hidden fees. You get a clear quote before any work begins.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`,
  },
  {
    title: "Certified Professionals",
    desc: "Our team is fully licensed, insured and trained to Australian standards.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  },
  {
    title: "Satisfaction Guaranteed",
    desc: "Not happy? We come back and make it right. Your satisfaction is our commitment.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`,
  },
];
---

<section class="bg-white py-24 px-6">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- Left: text -->
      <div>
        <p class="text-sky-600 font-semibold text-sm uppercase tracking-widest mb-3">Why Choose Us</p>
        <h2 class="text-4xl md:text-5xl font-bold text-slate-900 leading-tight mb-6">
          Quality work you can count on
        </h2>
        <p class="text-slate-500 text-lg leading-relaxed mb-10">
          With over 10 years serving Brisbane, we've built a reputation for showing up, doing the job right, and leaving your home better than we found it.
        </p>

        <!-- Features grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {features.map((f) => (
            <div class="flex gap-4">
              <div class="w-11 h-11 bg-sky-50 rounded-xl flex items-center justify-center text-sky-600 shrink-0">
                <Fragment set:html={f.icon} />
              </div>
              <div>
                <h3 class="font-bold text-slate-900 mb-1">{f.title}</h3>
                <p class="text-slate-500 text-sm leading-relaxed">{f.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: stats card -->
      <div class="relative">
        <div class="bg-slate-900 rounded-3xl p-10 text-white">
          <p class="text-slate-400 text-sm uppercase tracking-widest mb-8">Our track record</p>

          <div class="grid grid-cols-2 gap-8 mb-10">
            <div>
              <p class="text-5xl font-bold text-white mb-1">10<span class="text-sky-400">+</span></p>
              <p class="text-slate-400 text-sm">Years in Brisbane</p>
            </div>
            <div>
              <p class="text-5xl font-bold text-white mb-1">500<span class="text-sky-400">+</span></p>
              <p class="text-slate-400 text-sm">Happy clients</p>
            </div>
            <div>
              <p class="text-5xl font-bold text-white mb-1">3<span class="text-sky-400">+</span></p>
              <p class="text-slate-400 text-sm">Services offered</p>
            </div>
            <div>
              <p class="text-5xl font-bold text-white mb-1">7<span class="text-sky-400">d</span></p>
              <p class="text-slate-400 text-sm">Available all week</p>
            </div>
          </div>

          <!-- Testimonial -->
          <div class="border-t border-slate-700 pt-8">
            <p class="text-slate-300 italic text-sm leading-relaxed mb-4">
              "Roldans did an incredible job on our bathroom renovation. Professional, on time, and the result was perfect. Highly recommended."
            </p>
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 bg-sky-500 rounded-full flex items-center justify-center text-white font-bold text-sm">S</div>
              <div>
                <p class="text-white font-semibold text-sm">Sarah M.</p>
                <p class="text-slate-500 text-xs">Mount Gravatt, Brisbane</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Decorative accent -->
        <div class="absolute -top-4 -right-4 w-24 h-24 bg-sky-500/10 rounded-full blur-2xl -z-10"></div>
        <div class="absolute -bottom-4 -left-4 w-32 h-32 bg-sky-500/10 rounded-full blur-2xl -z-10"></div>
      </div>
    </div>
  </div>
</section>

<!-- CTA Banner -->
<section class="bg-sky-600 py-16 px-6">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-8">
    <div>
      <h2 class="text-3xl font-bold text-white mb-2">Ready to get started?</h2>
      <p class="text-sky-100">Contact us today and get a personalised quote within 24 hours.</p>
    </div>
    <div class="shrink-0">
      <a href="/#contacto">
        <Button text="Get a Free Quote" />
      </a>
    </div>
  </div>
</section>
