---
import Button from "../Button/index.astro";
---

<section class="bg-slate-50 py-24 px-6">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

      <!-- Left: info -->
      <div class="lg:pt-4">
        <p class="text-sky-600 font-semibold text-sm uppercase tracking-widest mb-3">Contact Us</p>
        <h2 class="text-4xl md:text-5xl font-bold text-slate-900 leading-tight mb-6">
          Get a free quote today
        </h2>
        <p class="text-slate-500 text-lg leading-relaxed mb-10">
          Fill in the form and one of our professionals will get back to you within 24 hours with a personalised quote — no obligation.
        </p>

        <!-- Contact details -->
        <div class="flex flex-col gap-5">
          <a href="tel:0466018580" class="flex items-center gap-4 group">
            <div class="w-12 h-12 bg-sky-50 rounded-xl flex items-center justify-center text-sky-600 group-hover:bg-sky-100 transition-colors shrink-0">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.56 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
            </div>
            <div>
              <p class="text-xs text-slate-400 uppercase tracking-wider">Phone</p>
              <p class="text-slate-900 font-semibold">0466 018 580</p>
            </div>
          </a>

          <a href="mailto:crmmultiservises@hotmail.com" class="flex items-center gap-4 group">
            <div class="w-12 h-12 bg-sky-50 rounded-xl flex items-center justify-center text-sky-600 group-hover:bg-sky-100 transition-colors shrink-0">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </div>
            <div>
              <p class="text-xs text-slate-400 uppercase tracking-wider">Email</p>
              <p class="text-slate-900 font-semibold">crmmultiservises@hotmail.com</p>
            </div>
          </a>

          <div class="flex items-center gap-4">
            <div class="w-12 h-12 bg-sky-50 rounded-xl flex items-center justify-center text-sky-600 shrink-0">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
            </div>
            <div>
              <p class="text-xs text-slate-400 uppercase tracking-wider">Hours</p>
              <p class="text-slate-900 font-semibold">Monday – Sunday · 7:00 – 18:00</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: form -->
      <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8">
        <h3 class="text-xl font-bold text-slate-900 mb-1">Request a Quote</h3>
        <p class="text-slate-500 text-sm mb-7">No commitment required. We'll respond within 24 hours.</p>

        <form
          id="contact-form"
          method="POST"
          action="/api/contact"
          novalidate
          class="flex flex-col gap-5"
        >
          <!-- Honeypot -->
          <input type="text" name="company" tabindex="-1" autocomplete="off" class="hidden" />

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div class="flex flex-col gap-1.5">
              <label for="nombre" class="text-sm font-semibold text-slate-700">Full Name</label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                required
                minlength="3"
                placeholder="John Smith"
                class="border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-sky-500 focus:border-transparent transition-all"
              />
            </div>
            <div class="flex flex-col gap-1.5">
              <label for="telefono" class="text-sm font-semibold text-slate-700">Phone</label>
              <input
                type="tel"
                id="telefono"
                name="telefono"
                required
                inputmode="numeric"
                autocomplete="tel"
                pattern="[\d\s\+\-\(\)]{8,20}"
                placeholder="0400 000 000"
                title="Only numbers, spaces, +, -, and ()"
                class="border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-sky-500 focus:border-transparent transition-all"
              />
            </div>
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="servicio" class="text-sm font-semibold text-slate-700">Service Required</label>
            <select
              id="servicio"
              name="servicio"
              required
              class="border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-sky-500 focus:border-transparent transition-all appearance-none bg-white"
            >
              <option value="">Select a service...</option>
              <option value="reparacion">Repair</option>
              <option value="instalacion">Installation</option>
              <option value="mantenimiento">Maintenance</option>
            </select>
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="mensaje" class="text-sm font-semibold text-slate-700">Message</label>
            <textarea
              id="mensaje"
              name="mensaje"
              rows="4"
              required
              minlength="10"
              placeholder="Describe what you need and we'll get back to you with a quote..."
              class="border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-sky-500 focus:border-transparent transition-all resize-none"
            ></textarea>
          </div>

          <div id="form-messages" class="hidden">
            <p id="success-message" class="hidden items-center gap-2 text-green-700 bg-green-50 border border-green-200 rounded-xl px-4 py-3 text-sm font-medium">
              ✓ Message sent! We'll be in touch within 24 hours.
            </p>
            <p id="error-message" class="hidden items-center gap-2 text-red-700 bg-red-50 border border-red-200 rounded-xl px-4 py-3 text-sm font-medium"></p>
          </div>

          <Button text="Send Request" type="submit" id="submit-btn" />

          <p class="text-center text-xs text-slate-400">
            By submitting you agree to be contacted by our team. No spam, ever.
          </p>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const successMsg = document.getElementById("success-message");
  const errorMsg = document.getElementById("error-message");
  const messagesContainer = document.getElementById("form-messages");
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    hideMessages();

    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    const formData = new FormData(form);

    try {
      submitBtn.disabled = true;
      const res = await fetch(form.action, { method: "POST", body: formData });
      const result = await res.json();

      if (!res.ok) throw new Error(result.error || "Unexpected error");

      showSuccess();
      form.reset();
    } catch (err: unknown) {
      showError(err instanceof Error ? err.message : "Could not send the form. Please try again.");
    } finally {
      submitBtn.disabled = false;
    }
  });

  function showSuccess() {
    messagesContainer?.classList.remove("hidden");
    successMsg?.classList.remove("hidden");
    successMsg?.classList.add("flex");
  }

  function showError(msg: string) {
    messagesContainer?.classList.remove("hidden");
    errorMsg!.textContent = "✕ " + msg;
    errorMsg?.classList.remove("hidden");
    errorMsg?.classList.add("flex");
  }

  function hideMessages() {
    messagesContainer?.classList.add("hidden");
    successMsg?.classList.add("hidden");
    successMsg?.classList.remove("flex");
    errorMsg?.classList.add("hidden");
    errorMsg?.classList.remove("flex");
  }
</script>
