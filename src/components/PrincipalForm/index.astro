---
import Button from "../Button/index.astro";
---

<div
  class="relative bg-gradient-to-br from-white to-sky-50 p-8 lg:p-12 rounded-3xl shadow-2xl max-w-4xl mx-auto border border-sky-100 overflow-hidden"
>
  <!-- Decorative Elements -->
  <div
    class="absolute top-0 right-0 w-64 h-64 bg-sky-200 rounded-full blur-3xl opacity-20 -z-0"
  >
  </div>
  <div
    class="absolute bottom-0 left-0 w-48 h-48 bg-sky-300 rounded-full blur-2xl opacity-20 -z-0"
  >
  </div>

  <div class="relative z-10">
    <!-- Header -->
    <div class="mb-8">
      <div
        class="inline-flex items-center gap-2 bg-sky-100 border border-sky-200 rounded-full px-4 py-2 mb-4"
      >
        <svg
          class="w-5 h-5 text-sky-600"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
          ></path>
        </svg>
        <span class="text-sky-700 text-sm font-medium"
          >Presupuesto Gratuito</span
        >
      </div>

      <h2 class="text-3xl lg:text-4xl font-bold text-gray-800 mb-3">
        Solicita tu presupuesto sin compromiso
      </h2>
      <p class="text-lg text-gray-600 leading-relaxed">
        Completa el formulario y uno de nuestros profesionales se pondrá en
        contacto con vos a la brevedad.
      </p>
    </div>

    <form
      id="contact-form"
      method="POST"
      action="/api/contact"
      novalidate
      class="space-y-6"
    >
      <!-- Honeypot (anti bots) -->
      <input
        type="text"
        name="company"
        tabindex="-1"
        autocomplete="off"
        class="hidden"
      />

      <!-- Name Field -->
      <div class="group">
        <label
          for="nombre"
          class="flex items-center gap-2 font-semibold text-gray-700 mb-2"
        >
          <svg
            class="w-5 h-5 text-sky-600"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
            ></path>
          </svg>
          Nombre completo
          <span class="text-red-500">*</span>
        </label>
        <input
          type="text"
          id="nombre"
          name="nombre"
          required
          minlength="3"
          placeholder="Ej: Juan Pérez"
          class="w-full border-2 border-gray-200 rounded-xl p-4 focus:outline-none focus:border-sky-500 focus:ring-4 focus:ring-sky-100 transition-all duration-300 bg-white hover:border-sky-300"
        />
      </div>

      <!-- Phone Field -->
      <div class="group">
        <label
          for="telefono"
          class="flex items-center gap-2 font-semibold text-gray-700 mb-2"
        >
          <svg
            class="w-5 h-5 text-sky-600"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
            ></path>
          </svg>
          Teléfono
          <span class="text-red-500">*</span>
        </label>
        <input
          type="tel"
          id="telefono"
          name="telefono"
          required
          inputmode="numeric"
          autocomplete="tel"
          placeholder="Ej: +54 9 11 1234-5678"
          class="w-full border-2 border-gray-200 rounded-xl p-4 focus:outline-none focus:border-sky-500 focus:ring-4 focus:ring-sky-100 transition-all duration-300 bg-white hover:border-sky-300"
        />
      </div>

      <!-- Service Field -->
      <div class="group">
        <label
          for="servicio"
          class="flex items-center gap-2 font-semibold text-gray-700 mb-2"
        >
          <svg
            class="w-5 h-5 text-sky-600"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
            ></path>
          </svg>
          Servicio requerido
          <span class="text-red-500">*</span>
        </label>
        <div class="relative">
          <select
            id="servicio"
            name="servicio"
            required
            class="w-full appearance-none border-2 border-gray-200 rounded-xl p-4 pr-12 focus:outline-none focus:border-sky-500 focus:ring-4 focus:ring-sky-100 transition-all duration-300 bg-white hover:border-sky-300 cursor-pointer"
          >
            <option value="">Selecciona una opción</option>
            <option value="reparacion">Reparación</option>
            <option value="instalacion">Instalación</option>
            <option value="mantenimiento">Mantenimiento</option>
          </select>
          <svg
            class="absolute right-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400 pointer-events-none"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 9l-7 7-7-7"></path>
          </svg>
        </div>
      </div>

      <!-- Message Field -->
      <div class="group">
        <label
          for="mensaje"
          class="flex items-center gap-2 font-semibold text-gray-700 mb-2"
        >
          <svg
            class="w-5 h-5 text-sky-600"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"
            ></path>
          </svg>
          Mensaje
          <span class="text-red-500">*</span>
        </label>
        <textarea
          id="mensaje"
          name="mensaje"
          rows="5"
          required
          minlength="10"
          placeholder="Cuéntanos más sobre tu proyecto o necesidad..."
          class="w-full border-2 border-gray-200 rounded-xl p-4 focus:outline-none focus:border-sky-500 focus:ring-4 focus:ring-sky-100 transition-all duration-300 bg-white hover:border-sky-300 resize-none"
        ></textarea>
        <p class="text-sm text-gray-500 mt-2">Mínimo 10 caracteres</p>
      </div>

      <!-- Messages Container -->
      <div id="form-messages" class="hidden">
        <div
          id="success-message"
          class="hidden bg-green-50 border-2 border-green-200 rounded-xl p-4 flex items-start gap-3"
        >
          <svg
            class="w-6 h-6 text-green-600 flex-shrink-0 mt-0.5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <div>
            <p class="text-green-800 font-semibold">
              ¡Mensaje enviado con éxito!
            </p>
            <p class="text-green-700 text-sm mt-1">
              Nos pondremos en contacto contigo pronto.
            </p>
          </div>
        </div>

        <div
          id="error-message"
          class="hidden bg-red-50 border-2 border-red-200 rounded-xl p-4 flex items-start gap-3"
        >
          <svg
            class="w-6 h-6 text-red-600 flex-shrink-0 mt-0.5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <div>
            <p class="text-red-800 font-semibold">Error al enviar</p>
            <p class="text-red-700 text-sm mt-1" id="error-text"></p>
          </div>
        </div>
      </div>

      <!-- Submit Button -->
      <div class="pt-4">
        <Button text="Solicitar presupuesto" type="submit" id="submit-btn" />
        <p class="text-center text-sm text-gray-500 mt-4">
          <svg
            class="w-4 h-4 inline-block mr-1"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
            ></path>
          </svg>
          Tus datos están seguros y protegidos
        </p>
      </div>
    </form>
  </div>
</div>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const successMsg = document.getElementById("success-message");
  const errorMsg = document.getElementById("error-message");
  const messagesContainer = document.getElementById("form-messages");
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;

  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    hideMessages();

    // HTML5 validation
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    const formData = new FormData(form);

    try {
      submitBtn.disabled = true;

      const res = await fetch(form.action, {
        method: "POST",
        body: formData,
      });

      const result = await res.json();

      if (!res.ok) {
        throw new Error(result.error || "Error inesperado");
      }

      showSuccess();
      form.reset();
    } catch (err: any) {
      showError(err.message || "No se pudo enviar el formulario");
    } finally {
      submitBtn.disabled = false;
    }
  });

  function showSuccess() {
    messagesContainer?.classList.remove("hidden");
    successMsg?.classList.remove("hidden");
  }

  function showError(msg: string) {
    messagesContainer?.classList.remove("hidden");
    const errorText = document.getElementById("error-text");
    if (errorText) errorText.textContent = msg;
    errorMsg?.classList.remove("hidden");
  }

  function hideMessages() {
    messagesContainer?.classList.add("hidden");
    successMsg?.classList.add("hidden");
    errorMsg?.classList.add("hidden");
  }
</script>
