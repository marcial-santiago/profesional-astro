---
export const prerender = false;

import BaseLayaout from "../layouts/BaseLayaout.astro";
import { prisma } from "../lib/prisma";
import { isAdminAuthenticated } from "../middleware/auth.middleware";

const isLoggedIn = await isAdminAuthenticated(Astro.cookies);

let messages: any[] = [];
let visits: any[] = [];
let workTypes: any[] = [];

if (isLoggedIn) {
  messages = await prisma.message.findMany({
    orderBy: { createdAt: "desc" },
    take: 50,
  });
  visits = await prisma.visit.findMany({
    include: { workType: true },
    orderBy: { date: "desc" },
    take: 50,
  });
  workTypes = await prisma.workType.findMany({ take: 100 });
}
---

<BaseLayaout>
  <div class="min-h-screen bg-slate-50 text-slate-800 font-sans">
    <div class="max-w-6xl mx-auto px-8 py-10">
      {
        isLoggedIn ? (
          <>
            <div class="flex items-center justify-between mb-8">
              <div>
                <h1 class="text-3xl font-bold tracking-tight">Panel Administrativo</h1>
                <p class="text-sm text-slate-500 mt-1">
                  Gestiona consultas y turnos agendados
                </p>
              </div>

              <div class="flex items-center gap-4">
                <button
                  id="logout-btn"
                  class="text-sm text-slate-500 hover:text-slate-900 transition"
                >
                  Cerrar sesión
                </button>
              </div>
            </div>

            <!-- Tabs Navigation -->
            <div class="flex border-b border-slate-200 mb-8 gap-8">
              <button class="tab-btn active border-b-2 border-blue-600 pb-3 text-sm font-bold text-slate-900" data-tab="visits">Visitas</button>
              <button class="tab-btn pb-3 text-sm font-medium text-slate-500 hover:text-slate-800" data-tab="messages">Mensajes</button>
              <button class="tab-btn pb-3 text-sm font-medium text-slate-500 hover:text-slate-800" data-tab="settings">Configuración</button>
            </div>

            <!-- Visits Tab -->
            <div id="tab-visits" class="tab-content">
               <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                 {visits.length === 0 && (
                   <p class="col-span-2 text-center py-20 text-slate-400">No hay visitas agendadas.</p>
                 )}
                 {visits.map(v => (
                   <div class="bg-white border border-slate-200 rounded-xl p-6 shadow-sm">
                     <div class="flex justify-between items-start mb-4">
                       <div>
                         <span class={`text-[10px] font-bold px-2 py-0.5 rounded-full uppercase ${
                           v.status === 'PENDING' ? 'bg-amber-100 text-amber-700' : 
                           v.status === 'CONFIRMED' ? 'bg-green-100 text-green-700' : 'bg-slate-100 text-slate-500'
                         }`}>
                           {v.status}
                         </span>
                         <h3 class="text-lg font-bold mt-2">{v.nombre}</h3>
                         <p class="text-sm text-slate-500">{v.telefono} • {v.email || 'Sin email'}</p>
                       </div>
                       <div class="text-right">
                         <p class="text-sm font-mono font-bold text-blue-600">{new Date(v.date).toLocaleDateString()}</p>
                         <p class="text-xs text-slate-400 font-mono">{new Date(v.date).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}</p>
                       </div>
                     </div>
                     <div class="bg-slate-50 rounded-lg p-3 text-sm mb-4 border border-slate-100">
                       <p><strong>Servicio:</strong> {v.workType?.name}</p>
                       {v.mensaje && <p class="mt-2 text-slate-600 italic">"{v.mensaje}"</p>}
                     </div>
                     <div class="flex gap-2">
                       {v.status === 'PENDING' && (
                         <button class="action-btn flex-1 bg-green-600 text-white py-1.5 rounded-lg text-xs font-bold hover:bg-green-700" data-id={v.id} data-status="CONFIRMED">Confirmar</button>
                       )}
                       <button class="action-btn flex-1 border border-slate-200 py-1.5 rounded-lg text-xs font-medium hover:bg-slate-50" data-id={v.id} data-status="CANCELLED">Cancelar</button>
                     </div>
                   </div>
                 ))}
               </div>
            </div>

            <!-- Messages Tab -->
            <div id="tab-messages" class="tab-content hidden">
              <ul class="space-y-4">
                {messages.length === 0 && (
                  <li class="bg-white border border-slate-200 rounded-xl p-10 text-center text-slate-500">
                    No hay mensajes por el momento.
                  </li>
                )}
                {messages.map((m) => (
                  <li class="group bg-white border border-slate-200 rounded-xl p-6 shadow-sm hover:shadow-md transition">
                    <div class="flex items-start justify-between gap-4">
                      <div class="space-y-1">
                        <p class="text-lg font-medium text-slate-900">
                          {m.nombre}
                        </p>
                        <p class="text-sm text-slate-500">{m.telefono}</p>
                      </div>

                      <span class="text-xs text-slate-400 whitespace-nowrap">
                        {new Date(m.createdAt).toLocaleString()}
                      </span>
                    </div>

                    <div class="my-4 h-px bg-slate-100" />

                    <span class="inline-flex items-center rounded-md bg-blue-50 px-2 py-0.5 text-xs font-medium text-blue-700">
                      {m.servicio}
                    </span>

                    <p class="mt-4 text-slate-700 leading-relaxed">{m.mensaje}</p>
                  </li>
                ))}
              </ul>
            </div>

            <!-- Settings Tab -->
            <div id="tab-settings" class="tab-content hidden">
              <div class="bg-white border border-slate-200 rounded-xl p-8 mb-8">
                <div class="flex items-center justify-between mb-6">
                  <h2 class="text-xl font-bold">Tipos de Servicios</h2>
                  <button id="add-service-btn" class="bg-blue-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-blue-700 transition">
                    + Agregar Servicio
                  </button>
                </div>

                <!-- Modal para crear/editar servicio -->
                <div id="service-modal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50">
                  <div class="bg-white rounded-xl p-8 max-w-md w-full mx-4 shadow-xl">
                    <h3 id="modal-title" class="text-lg font-bold mb-4">Nuevo Servicio</h3>

                    <form id="service-form" class="space-y-4">
                      <div>
                        <label for="service-name" class="block text-sm font-medium text-slate-700 mb-1">
                          Nombre del Servicio <span class="text-red-500">*</span>
                        </label>
                        <input
                          id="service-name"
                          type="text"
                          name="name"
                          required
                          maxlength="100"
                          class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500/30 focus:border-blue-500 outline-none"
                          placeholder="Ej: Limpieza Residencial"
                        />
                      </div>

                      <div>
                        <label for="service-desc" class="block text-sm font-medium text-slate-700 mb-1">
                          Descripción
                        </label>
                        <textarea
                          id="service-desc"
                          name="description"
                          rows="2"
                          maxlength="500"
                          class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500/30 focus:border-blue-500 outline-none resize-none"
                          placeholder="Descripción breve del servicio"
                        ></textarea>
                      </div>

                      <div class="grid grid-cols-2 gap-4">
                        <div>
                          <label for="service-duration" class="block text-sm font-medium text-slate-700 mb-1">
                            Duración (min) <span class="text-red-500">*</span>
                          </label>
                          <input
                            id="service-duration"
                            type="number"
                            name="duration"
                            required
                            min="15"
                            step="15"
                            value="60"
                            class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500/30 focus:border-blue-500 outline-none"
                            placeholder="60"
                          />
                        </div>

                        <div>
                          <label for="service-price" class="block text-sm font-medium text-slate-700 mb-1">
                            Precio (USD) <span class="text-red-500">*</span>
                          </label>
                          <input
                            id="service-price"
                            type="number"
                            name="price"
                            required
                            min="0.01"
                            step="0.01"
                            value="10"
                            class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500/30 focus:border-blue-500 outline-none"
                            placeholder="10.00"
                          />
                        </div>
                      </div>

                      <div id="form-error" class="hidden text-sm text-red-600 bg-red-50 p-2 rounded-lg"></div>

                      <div class="flex gap-3 pt-4">
                        <button type="button" id="modal-cancel" class="flex-1 border border-slate-200 text-slate-700 py-2 rounded-lg text-sm font-medium hover:bg-slate-50 transition">
                          Cancelar
                        </button>
                        <button type="submit" class="flex-1 bg-blue-600 text-white py-2 rounded-lg text-sm font-medium hover:bg-blue-700 transition">
                          Guardar
                        </button>
                      </div>
                    </form>
                  </div>
                </div>

                <!-- Lista de servicios -->
                <div id="services-list" class="space-y-3">
                  {workTypes.map(wt => (
                    <div class="border border-slate-100 rounded-lg p-4 bg-slate-50 flex items-start justify-between hover:shadow-sm transition">
                      <div class="flex-1">
                        <p class="font-bold text-slate-900">{wt.name}</p>
                        {wt.description && <p class="text-xs text-slate-600 mt-1">{wt.description}</p>}
                        <p class="text-xs text-slate-500 mt-2">
                          ⏱️ {wt.duration} min &nbsp;·&nbsp;
                          💵 USD {(wt.price ?? 10).toFixed(2)} &nbsp;·&nbsp;
                          {wt.isActive ? '✓ Activo' : '⊘ Inactivo'}
                        </p>
                      </div>
                      <div class="flex gap-2 ml-4">
                        <button class="edit-service-btn px-3 py-1 text-xs bg-blue-50 text-blue-600 rounded hover:bg-blue-100 transition" data-id={wt.id} data-price={wt.price ?? 10}>
                          Editar
                        </button>
                        <button class="delete-service-btn px-3 py-1 text-xs bg-red-50 text-red-600 rounded hover:bg-red-100 transition" data-id={wt.id}>
                          Eliminar
                        </button>
                      </div>
                    </div>
                  ))}
                </div>

                {workTypes.length === 0 && (
                  <p class="text-center text-slate-500 py-12">No hay servicios creados. Crea uno para comenzar.</p>
                )}
              </div>

              <!-- CSV Import Section -->
              <div class="bg-white border border-slate-200 rounded-xl p-8">
                <h2 class="text-xl font-bold mb-2">Importar desde CSV</h2>
                <p class="text-sm text-slate-500 mb-6">
                  El archivo debe tener las columnas: <code class="bg-slate-100 px-1 rounded text-xs">nombre, descripcion, duracion, precio</code>
                </p>

                <!-- Download template -->
                <a
                  id="download-template"
                  href="#"
                  class="inline-flex items-center gap-2 text-sm text-blue-600 hover:underline mb-6"
                >
                  ↓ Descargar plantilla de ejemplo
                </a>

                <!-- Drop zone -->
                <div
                  id="csv-dropzone"
                  class="border-2 border-dashed border-slate-200 rounded-xl p-10 text-center cursor-pointer hover:border-blue-400 hover:bg-blue-50/30 transition"
                >
                  <p class="text-4xl mb-3">📂</p>
                  <p class="text-sm font-medium text-slate-700">Arrastrá tu archivo CSV aquí</p>
                  <p class="text-xs text-slate-400 mt-1">o hacé click para seleccionar</p>
                  <input id="csv-input" type="file" accept=".csv" class="hidden" />
                </div>

                <!-- Preview table -->
                <div id="csv-preview" class="hidden mt-6">
                  <div class="flex items-center justify-between mb-3">
                    <p id="csv-row-count" class="text-sm font-medium text-slate-700"></p>
                    <div class="flex gap-2">
                      <button id="csv-cancel" class="text-sm text-slate-500 hover:text-slate-800 transition">
                        Cancelar
                      </button>
                      <button id="csv-import-btn" class="bg-blue-600 text-white px-4 py-1.5 rounded-lg text-sm font-medium hover:bg-blue-700 transition">
                        Importar
                      </button>
                    </div>
                  </div>

                  <div class="overflow-x-auto rounded-lg border border-slate-200">
                    <table class="w-full text-sm">
                      <thead class="bg-slate-50">
                        <tr>
                          <th class="text-left px-4 py-2 text-xs font-semibold text-slate-500 uppercase">Nombre</th>
                          <th class="text-left px-4 py-2 text-xs font-semibold text-slate-500 uppercase">Descripción</th>
                          <th class="text-left px-4 py-2 text-xs font-semibold text-slate-500 uppercase">Duración</th>
                          <th class="text-left px-4 py-2 text-xs font-semibold text-slate-500 uppercase">Precio USD</th>
                        </tr>
                      </thead>
                      <tbody id="csv-table-body" class="divide-y divide-slate-100"></tbody>
                    </table>
                  </div>
                </div>

                <!-- Import error -->
                <div id="csv-error" class="hidden mt-4 text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-4 py-3"></div>

                <!-- Import success -->
                <div id="csv-success" class="hidden mt-4 text-sm text-green-700 bg-green-50 border border-green-200 rounded-lg px-4 py-3"></div>
              </div>
            </div>
          </>
        ) : (
          <>
            <div class="min-h-[75vh] flex items-center justify-center">
              <div class="w-full max-w-sm bg-white border border-slate-200 rounded-xl p-8 shadow-sm">
                <h1 class="text-2xl font-bold tracking-tight ">
                  Acceso Especial
                </h1>
                <p class="text-sm text-slate-500 mt-1 mb-6">
                  Solo personal autorizado
                </p>

                <form id="login-form" class="space-y-4">
                  <input
                    name="user"
                    placeholder="Usuario"
                    required
                    class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500/30 focus:border-blue-500"
                  />

                  <input
                    name="password"
                    type="password"
                    placeholder="Contraseña"
                    required
                    class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500/30 focus:border-blue-500"
                  />

                  <p id="login-error" class="text-sm text-red-600 hidden">
                    Credenciales inválidas
                  </p>

                  <button
                    type="submit"
                    class="w-full rounded-lg bg-blue-600 text-white py-2.5 text-sm font-bold hover:bg-blue-700 transition"
                  >
                    Entrar
                  </button>
                </form>
              </div>
            </div>
          </>
        )
      }
    </div>

    <script>
      // Login handle
      const loginForm = document.getElementById("login-form") as HTMLFormElement;
      const errorEl = document.getElementById("login-error");
      const logoutBtn = document.getElementById("logout-btn");

      loginForm?.addEventListener("submit", async (e) => {
        e.preventDefault();
        errorEl?.classList.add("hidden");
        const formData = new FormData(loginForm);
        const data = Object.fromEntries(formData.entries());
        
        try {
          const res = await fetch("/api/admin/login", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(data),
          });

          if (!res.ok) throw new Error();
          window.location.reload();
        } catch {
          errorEl?.classList.remove("hidden");
        }
      });

      logoutBtn?.addEventListener("click", async () => {
        await fetch("/api/admin/logout", { method: "POST" });
        window.location.reload();
      });

      // Tabs Handle
      document.querySelectorAll('.tab-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('.tab-btn').forEach(b => {
             b.classList.remove('active', 'border-b-2', 'border-blue-600', 'text-slate-900');
             b.classList.add('text-slate-500', 'font-medium');
          });
          btn.classList.add('active', 'border-b-2', 'border-blue-600', 'text-slate-900');
          btn.classList.remove('text-slate-500', 'font-medium');

          const tab = btn.getAttribute('data-tab');
          document.querySelectorAll('.tab-content').forEach(c => c.classList.add('hidden'));
          document.getElementById(`tab-${tab}`)?.classList.remove('hidden');
        });
      });

      // Visit Actions
      document.querySelectorAll('.action-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
          const id = btn.getAttribute('data-id');
          const status = btn.getAttribute('data-status');

          if (!confirm(`¿Confirmas el cambio a ${status}?`)) return;

          try {
            const res = await fetch('/api/admin/visits', {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ id: Number(id), status })
            });

            if (res.ok) location.reload();
          } catch (e) {
            alert('Error al actualizar');
          }
        });
      });

      // Service CRUD
      let editingServiceId: number | null = null;

      const modal = document.getElementById('service-modal');
      const modalTitle = document.getElementById('modal-title');
      const form = document.getElementById('service-form') as HTMLFormElement;
      const addBtn = document.getElementById('add-service-btn');
      const cancelBtn = document.getElementById('modal-cancel');
      const errorDiv = document.getElementById('form-error');

      // Open modal for new service
      addBtn?.addEventListener('click', () => {
        editingServiceId = null;
        modalTitle!.textContent = 'Nuevo Servicio';
        form.reset();
        errorDiv?.classList.add('hidden');
        modal?.classList.remove('hidden');
      });

      // Close modal
      cancelBtn?.addEventListener('click', () => {
        modal?.classList.add('hidden');
        form.reset();
        editingServiceId = null;
      });

      // Edit service
      document.querySelectorAll('.edit-service-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
          const id = parseInt(btn.getAttribute('data-id') || '0');
          if (!id) return;

          const card = btn.closest('[class*="border-slate-100"]');
          if (!card) return;

          const name = card.querySelector('p.font-bold')?.textContent || '';
          const desc = card.querySelector('p.text-slate-600')?.textContent || '';
          const durationMatch = card.textContent?.match(/⏱️\s+(\d+)/);
          const duration = durationMatch ? parseInt(durationMatch[1]) : 60;
          const price = parseFloat(btn.getAttribute('data-price') || '10');

          editingServiceId = id;
          modalTitle!.textContent = 'Editar Servicio';
          (document.getElementById('service-name') as HTMLInputElement).value = name;
          (document.getElementById('service-desc') as HTMLTextAreaElement).value = desc;
          (document.getElementById('service-duration') as HTMLInputElement).value = duration.toString();
          (document.getElementById('service-price') as HTMLInputElement).value = price.toString();
          errorDiv?.classList.add('hidden');
          modal?.classList.remove('hidden');
        });
      });

      // Submit form
      form?.addEventListener('submit', async (e) => {
        e.preventDefault();

        const name = (document.getElementById('service-name') as HTMLInputElement).value.trim();
        const description = (document.getElementById('service-desc') as HTMLTextAreaElement).value.trim();
        const duration = parseInt((document.getElementById('service-duration') as HTMLInputElement).value);
        const price = parseFloat((document.getElementById('service-price') as HTMLInputElement).value);

        if (!name) {
          showError('El nombre es requerido');
          return;
        }

        try {
          const method = editingServiceId ? 'PUT' : 'POST';
          const endpoint = editingServiceId
            ? `/api/admin/work-types/${editingServiceId}`
            : '/api/admin/work-types';

          const res = await fetch(endpoint, {
            method,
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name, description, duration, price })
          });

          if (!res.ok) {
            const error = await res.json();
            showError(error.message || 'Error al guardar');
            return;
          }

          location.reload();
        } catch (e) {
          showError('Error al guardar el servicio');
        }
      });

      // Delete service
      document.querySelectorAll('.delete-service-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
          const id = btn.getAttribute('data-id');
          const name = btn.closest('[class*="border-slate-100"]')?.querySelector('p.font-bold')?.textContent;

          if (!confirm(`¿Eliminar servicio "${name}"?`)) return;

          try {
            const res = await fetch(`/api/admin/work-types/${id}`, {
              method: 'DELETE'
            });

            if (res.ok) location.reload();
            else alert('Error al eliminar');
          } catch (e) {
            alert('Error al eliminar');
          }
        });
      });

      function showError(message: string) {
        errorDiv!.textContent = message;
        errorDiv?.classList.remove('hidden');
      }

      // Close modal on background click
      modal?.addEventListener('click', (e) => {
        if (e.target === modal) {
          modal.classList.add('hidden');
        }
      });

      // ── CSV Import ──────────────────────────────────────────────────

      // Download template
      document.getElementById('download-template')?.addEventListener('click', (e) => {
        e.preventDefault();
        const csv = 'nombre,descripcion,duracion,precio\nLimpieza Residencial,Limpieza completa del hogar,120,10\nReparación de Fugas,Detección y reparación de pérdidas,60,10';
        const blob = new Blob([csv], { type: 'text/csv' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = 'servicios_plantilla.csv';
        a.click();
        URL.revokeObjectURL(url);
      });

      interface CsvRow {
        name: string;
        description: string;
        duration: number;
        price: number;
      }

      let parsedRows: CsvRow[] = [];

      function parseCSV(text: string): CsvRow[] {
        const lines = text.trim().split(/\r?\n/);
        if (lines.length < 2) throw new Error('El archivo debe tener al menos una fila de datos');

        // Normalize headers
        const headers = lines[0].split(',').map(h => h.trim().toLowerCase().replace(/[^a-záéíóúñ]/gi, ''));

        const nameIdx = headers.findIndex(h => h.includes('nombre') || h.includes('name'));
        const descIdx = headers.findIndex(h => h.includes('desc'));
        const durIdx  = headers.findIndex(h => h.includes('dur'));
        const priceIdx = headers.findIndex(h => h.includes('prec') || h.includes('price'));

        if (nameIdx === -1) throw new Error('Columna "nombre" no encontrada');
        if (durIdx === -1)  throw new Error('Columna "duracion" no encontrada');
        if (priceIdx === -1) throw new Error('Columna "precio" no encontrada');

        const rows: CsvRow[] = [];

        for (let i = 1; i < lines.length; i++) {
          const line = lines[i].trim();
          if (!line) continue;

          // Handle quoted fields
          const cols = line.match(/(".*?"|[^,]+|(?<=,)(?=,)|^(?=,)|(?<=,)$)/g) ?? line.split(',');
          const clean = (s: string | undefined) => (s ?? '').replace(/^"|"$/g, '').trim();

          const name = clean(cols[nameIdx]);
          if (!name) throw new Error(`Fila ${i + 1}: el nombre es requerido`);

          const duration = parseInt(clean(cols[durIdx]));
          if (isNaN(duration) || duration < 15) throw new Error(`Fila ${i + 1}: duración inválida`);

          const price = parseFloat(clean(cols[priceIdx]));
          if (isNaN(price) || price <= 0) throw new Error(`Fila ${i + 1}: precio inválido`);

          rows.push({
            name,
            description: descIdx !== -1 ? clean(cols[descIdx]) : '',
            duration,
            price,
          });
        }

        return rows;
      }

      function showCsvPreview(rows: CsvRow[]) {
        const preview = document.getElementById('csv-preview')!;
        const rowCount = document.getElementById('csv-row-count')!;
        const tbody = document.getElementById('csv-table-body')!;

        tbody.innerHTML = rows.slice(0, 20).map(r => `
          <tr class="hover:bg-slate-50">
            <td class="px-4 py-2 font-medium text-slate-900">${r.name}</td>
            <td class="px-4 py-2 text-slate-500 max-w-[200px] truncate">${r.description || '—'}</td>
            <td class="px-4 py-2 text-slate-700">${r.duration} min</td>
            <td class="px-4 py-2 text-green-700 font-medium">USD ${r.price.toFixed(2)}</td>
          </tr>
        `).join('');

        rowCount.textContent = `${rows.length} servicio${rows.length !== 1 ? 's' : ''} listos para importar${rows.length > 20 ? ' (mostrando los primeros 20)' : ''}`;
        preview.classList.remove('hidden');
      }

      function hideCsvPreview() {
        document.getElementById('csv-preview')!.classList.add('hidden');
        document.getElementById('csv-error')!.classList.add('hidden');
        document.getElementById('csv-success')!.classList.add('hidden');
        parsedRows = [];
        (document.getElementById('csv-input') as HTMLInputElement).value = '';
      }

      function handleFile(file: File) {
        if (!file.name.endsWith('.csv')) {
          showCsvError('El archivo debe ser un CSV (.csv)');
          return;
        }

        document.getElementById('csv-error')!.classList.add('hidden');
        document.getElementById('csv-success')!.classList.add('hidden');

        const reader = new FileReader();
        reader.onload = (e) => {
          try {
            parsedRows = parseCSV(e.target?.result as string);
            showCsvPreview(parsedRows);
          } catch (err: any) {
            showCsvError(err.message);
          }
        };
        reader.readAsText(file);
      }

      function showCsvError(msg: string) {
        const el = document.getElementById('csv-error')!;
        el.textContent = msg;
        el.classList.remove('hidden');
      }

      // Click to select file
      const dropzone = document.getElementById('csv-dropzone')!;
      const csvInput = document.getElementById('csv-input') as HTMLInputElement;

      dropzone.addEventListener('click', () => csvInput.click());
      csvInput.addEventListener('change', () => {
        if (csvInput.files?.[0]) handleFile(csvInput.files[0]);
      });

      // Drag and drop
      dropzone.addEventListener('dragover', (e) => {
        e.preventDefault();
        dropzone.classList.add('border-blue-400', 'bg-blue-50/30');
      });
      dropzone.addEventListener('dragleave', () => {
        dropzone.classList.remove('border-blue-400', 'bg-blue-50/30');
      });
      dropzone.addEventListener('drop', (e) => {
        e.preventDefault();
        dropzone.classList.remove('border-blue-400', 'bg-blue-50/30');
        const file = e.dataTransfer?.files[0];
        if (file) handleFile(file);
      });

      // Cancel
      document.getElementById('csv-cancel')?.addEventListener('click', hideCsvPreview);

      // Import
      document.getElementById('csv-import-btn')?.addEventListener('click', async () => {
        if (parsedRows.length === 0) return;

        const importBtn = document.getElementById('csv-import-btn') as HTMLButtonElement;
        importBtn.disabled = true;
        importBtn.textContent = 'Importando...';

        try {
          const res = await fetch('/api/admin/import-services', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(parsedRows.map(r => ({
              name: r.name,
              description: r.description || undefined,
              duration: r.duration,
              price: r.price,
            }))),
          });

          const result = await res.json();

          if (!res.ok) {
            showCsvError(result.error || 'Error al importar');
            importBtn.disabled = false;
            importBtn.textContent = 'Importar';
            return;
          }

          document.getElementById('csv-preview')!.classList.add('hidden');
          const successEl = document.getElementById('csv-success')!;
          successEl.textContent = `✓ ${result.imported} servicio${result.imported !== 1 ? 's' : ''} importado${result.imported !== 1 ? 's' : ''} correctamente.`;
          successEl.classList.remove('hidden');

          // Reload to show updated list
          setTimeout(() => location.reload(), 1500);
        } catch {
          showCsvError('Error de conexión. Intentá de nuevo.');
          importBtn.disabled = false;
          importBtn.textContent = 'Importar';
        }
      });
    </script>
  </div>
</BaseLayaout>
