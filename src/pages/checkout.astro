---
export const prerender = false;
import BaseLayaout from "../layouts/BaseLayaout.astro";
---

<BaseLayaout>
  <div class="min-h-screen bg-slate-50 py-16 px-4">
    <div class="max-w-2xl mx-auto">

      <!-- Back -->
      <a href="/#agenda" class="inline-flex items-center gap-2 text-sm text-slate-500 hover:text-slate-800 transition mb-8">
        ← Volver al agendador
      </a>

      <!-- Header -->
      <div class="mb-8">
        <h1 class="text-3xl font-bold text-slate-900">Confirmá tu turno</h1>
        <p class="text-slate-500 mt-1">Revisá los detalles y completá tus datos para finalizar.</p>
      </div>

      <!-- Summary card -->
      <div id="summary-card" class="bg-white border border-slate-200 rounded-2xl p-6 mb-6 shadow-sm">
        <h2 class="text-sm font-semibold text-slate-500 uppercase tracking-wide mb-4">Resumen de tu visita</h2>

        <div class="space-y-3">
          <div class="flex items-center justify-between">
            <span class="text-sm text-slate-600">Servicio</span>
            <span id="summary-service" class="text-sm font-semibold text-slate-900">—</span>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-sm text-slate-600">Fecha</span>
            <span id="summary-date" class="text-sm font-semibold text-slate-900">—</span>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-sm text-slate-600">Hora</span>
            <span id="summary-time" class="text-sm font-semibold text-slate-900">—</span>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-sm text-slate-600">Duración estimada</span>
            <span id="summary-duration" class="text-sm font-semibold text-slate-900">—</span>
          </div>
          <div class="border-t border-slate-100 pt-3 flex items-center justify-between">
            <span class="text-sm font-semibold text-slate-800">Total a pagar</span>
            <span id="summary-price" class="text-lg font-bold text-green-700">—</span>
          </div>
        </div>
      </div>

      <!-- Empty state (shown if no sessionStorage data) -->
      <div id="empty-state" class="hidden text-center py-20 bg-white border border-slate-200 rounded-2xl mb-6">
        <p class="text-4xl mb-4">📅</p>
        <p class="text-slate-600 font-medium">No hay ningún turno seleccionado.</p>
        <a href="/#agenda" class="mt-4 inline-block text-blue-600 text-sm font-medium hover:underline">
          Ir al agendador
        </a>
      </div>

      <!-- Contact form -->
      <div id="form-section" class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm">
        <h2 class="text-sm font-semibold text-slate-500 uppercase tracking-wide mb-4">Tus datos</h2>

        <form id="checkout-form" class="space-y-4" novalidate>
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label for="nombre" class="block text-sm font-medium text-slate-700 mb-1">
                Nombre completo <span class="text-red-500">*</span>
              </label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                required
                minlength="3"
                maxlength="100"
                placeholder="Juan García"
                class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition"
              />
              <p class="error-msg hidden text-xs text-red-500 mt-1"></p>
            </div>

            <div>
              <label for="telefono" class="block text-sm font-medium text-slate-700 mb-1">
                Teléfono <span class="text-red-500">*</span>
              </label>
              <input
                type="tel"
                id="telefono"
                name="telefono"
                required
                placeholder="+54 9 351 123 4567"
                class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition"
              />
              <p class="error-msg hidden text-xs text-red-500 mt-1"></p>
            </div>
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-slate-700 mb-1">
              Email <span class="text-slate-400">(opcional)</span>
            </label>
            <input
              type="email"
              id="email"
              name="email"
              placeholder="tu@email.com"
              class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition"
            />
          </div>

          <div>
            <label for="mensaje" class="block text-sm font-medium text-slate-700 mb-1">
              Nota adicional <span class="text-slate-400">(opcional)</span>
            </label>
            <textarea
              id="mensaje"
              name="mensaje"
              rows="3"
              maxlength="500"
              placeholder="Contanos brevemente qué necesitás..."
              class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition resize-none"
            ></textarea>
          </div>

          <!-- Error global -->
          <div id="form-error" class="hidden bg-red-50 border border-red-200 text-red-700 text-sm rounded-lg px-4 py-3"></div>

          <div class="flex flex-col gap-3 pt-1">
            <!-- Stripe payment -->
            <button
              type="button"
              id="stripe-btn"
              class="w-full bg-indigo-600 text-white py-3 rounded-xl font-bold text-sm hover:bg-indigo-700 transition shadow-md shadow-indigo-500/20 disabled:opacity-50 disabled:cursor-not-allowed flex items-center justify-center gap-2"
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                <path d="M13.976 9.15c-2.172-.806-3.356-1.426-3.356-2.409 0-.831.683-1.305 1.901-1.305 2.227 0 4.515.858 6.09 1.631l.89-5.494C18.252.975 15.697 0 12.165 0 9.667 0 7.589.654 6.104 1.872 4.56 3.147 3.757 4.992 3.757 7.218c0 4.039 2.467 5.76 6.476 7.219 2.585.92 3.445 1.574 3.445 2.583 0 .98-.84 1.545-2.354 1.545-1.875 0-4.965-.921-6.99-2.109l-.9 5.555C5.175 22.99 8.385 24 11.714 24c2.641 0 4.843-.624 6.328-1.813 1.664-1.305 2.525-3.236 2.525-5.732 0-4.128-2.524-5.851-6.591-7.305z"/>
              </svg>
              Pagar con Stripe · <span id="stripe-price-label">USD 10.00</span>
            </button>

            <!-- Confirm without payment -->
            <button
              type="submit"
              id="submit-btn"
              class="w-full border border-slate-200 text-slate-700 py-3 rounded-xl font-medium text-sm hover:bg-slate-50 transition disabled:opacity-50 disabled:cursor-not-allowed"
            >
              Solo confirmar turno (sin pago)
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Success overlay -->
  <div id="success-overlay" class="hidden fixed inset-0 bg-white flex items-center justify-center z-50">
    <div class="text-center max-w-sm px-4">
      <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6">
        <svg class="w-10 h-10 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <h2 class="text-2xl font-bold text-slate-900 mb-2">¡Turno Agendado!</h2>
      <p class="text-slate-500 text-sm mb-8">
        Recibimos tu solicitud. Te contactamos en menos de 24 horas para confirmarlo.
      </p>
      <a href="/" class="inline-block bg-blue-600 text-white px-6 py-2.5 rounded-xl text-sm font-medium hover:bg-blue-700 transition">
        Volver al inicio
      </a>
    </div>
  </div>
</BaseLayaout>

<script>
  interface CheckoutData {
    workTypeId: number;
    workTypeName: string;
    workTypeDuration: number;
    price: number;
    date: string;
    time: string;
  }

  function formatDate(dateStr: string): string {
    const [year, month, day] = dateStr.split("-").map(Number);
    const date = new Date(year, month - 1, day);
    return date.toLocaleDateString("es-AR", {
      weekday: "long",
      day: "numeric",
      month: "long",
      year: "numeric",
    });
  }

  function formatDuration(minutes: number): string {
    if (minutes < 60) return `${minutes} min`;
    const h = Math.floor(minutes / 60);
    const m = minutes % 60;
    return m === 0 ? `${h} hora${h > 1 ? "s" : ""}` : `${h}h ${m}min`;
  }

  // Load checkout data from sessionStorage
  const raw = sessionStorage.getItem("checkout");
  const summaryCard = document.getElementById("summary-card");
  const emptyState = document.getElementById("empty-state");
  const formSection = document.getElementById("form-section");

  if (!raw) {
    summaryCard?.classList.add("hidden");
    emptyState?.classList.remove("hidden");
    formSection?.classList.add("hidden");
  } else {
    const data: CheckoutData = JSON.parse(raw);

    const price = data.price ?? 10;
    const priceLabel = `USD ${price.toFixed(2)}`;

    const el = (id: string) => document.getElementById(id);
    el("summary-service")!.textContent = data.workTypeName;
    el("summary-date")!.textContent = formatDate(data.date);
    el("summary-time")!.textContent = data.time;
    el("summary-duration")!.textContent = formatDuration(data.workTypeDuration ?? 60);
    el("summary-price")!.textContent = priceLabel;
    el("stripe-price-label")!.textContent = priceLabel;

    // Stripe button
    const stripeBtn = document.getElementById("stripe-btn") as HTMLButtonElement;
    stripeBtn.addEventListener("click", async () => {
      stripeBtn.disabled = true;
      stripeBtn.textContent = "Redirigiendo...";

      try {
        const res = await fetch("/api/stripe/create-checkout-session", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ workTypeName: data.workTypeName, price }),
        });

        const result = await res.json();

        if (!res.ok || !result.url) {
          throw new Error(result.error || "Error al crear sesión de pago");
        }

        // Redirect to Stripe hosted checkout
        window.location.href = result.url;
      } catch (err: any) {
        const formError = document.getElementById("form-error")!;
        formError.textContent = err.message || "No se pudo iniciar el pago. Intentá de nuevo.";
        formError.classList.remove("hidden");
        stripeBtn.disabled = false;
        stripeBtn.innerHTML = `<svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M13.976 9.15c-2.172-.806-3.356-1.426-3.356-2.409 0-.831.683-1.305 1.901-1.305 2.227 0 4.515.858 6.09 1.631l.89-5.494C18.252.975 15.697 0 12.165 0 9.667 0 7.589.654 6.104 1.872 4.56 3.147 3.757 4.992 3.757 7.218c0 4.039 2.467 5.76 6.476 7.219 2.585.92 3.445 1.574 3.445 2.583 0 .98-.84 1.545-2.354 1.545-1.875 0-4.965-.921-6.99-2.109l-.9 5.555C5.175 22.99 8.385 24 11.714 24c2.641 0 4.843-.624 6.328-1.813 1.664-1.305 2.525-3.236 2.525-5.732 0-4.128-2.524-5.851-6.591-7.305z"/></svg> Pagar con Stripe · ${priceLabel}`;
      }
    });

    // Handle form submission (confirm without payment)
    const form = document.getElementById("checkout-form") as HTMLFormElement;
    const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
    const formError = document.getElementById("form-error")!;

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const nombre = (form.elements.namedItem("nombre") as HTMLInputElement).value.trim();
      const telefono = (form.elements.namedItem("telefono") as HTMLInputElement).value.trim();
      const email = (form.elements.namedItem("email") as HTMLInputElement).value.trim();
      const mensaje = (form.elements.namedItem("mensaje") as HTMLTextAreaElement).value.trim();

      // Inline validation
      let valid = true;

      if (nombre.length < 3) {
        showFieldError("nombre", "Ingresá tu nombre completo (mínimo 3 letras)");
        valid = false;
      } else {
        clearFieldError("nombre");
      }

      if (!telefono) {
        showFieldError("telefono", "El teléfono es requerido");
        valid = false;
      } else {
        clearFieldError("telefono");
      }

      if (!valid) return;

      submitBtn.disabled = true;
      submitBtn.textContent = "Enviando...";
      formError.classList.add("hidden");

      try {
        const res = await fetch("/api/visits", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            nombre,
            telefono,
            email: email || undefined,
            mensaje: mensaje || undefined,
            date: data.date,
            time: data.time,
            workTypeId: data.workTypeId,
          }),
        });

        const result = await res.json();

        if (!res.ok) {
          const msg =
            result.message ||
            result.error ||
            "No se pudo confirmar el turno. Intentá de nuevo.";
          formError.textContent = msg;
          formError.classList.remove("hidden");
          submitBtn.disabled = false;
          submitBtn.textContent = "Confirmar Turno";
          return;
        }

        // Success
        sessionStorage.removeItem("checkout");
        document.getElementById("success-overlay")?.classList.remove("hidden");
      } catch {
        formError.textContent = "Error de conexión. Verificá tu internet e intentá de nuevo.";
        formError.classList.remove("hidden");
        submitBtn.disabled = false;
        submitBtn.textContent = "Confirmar Turno";
      }
    });
  }

  function showFieldError(fieldId: string, message: string): void {
    const input = document.getElementById(fieldId)!;
    const errorEl = input.parentElement?.querySelector(".error-msg");
    input.classList.add("border-red-300");
    input.classList.remove("border-slate-200");
    if (errorEl) {
      errorEl.textContent = message;
      errorEl.classList.remove("hidden");
    }
  }

  function clearFieldError(fieldId: string): void {
    const input = document.getElementById(fieldId)!;
    const errorEl = input.parentElement?.querySelector(".error-msg");
    input.classList.remove("border-red-300");
    input.classList.add("border-slate-200");
    if (errorEl) {
      errorEl.classList.add("hidden");
    }
  }
</script>
