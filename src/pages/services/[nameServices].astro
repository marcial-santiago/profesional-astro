---
import BaseLayout from "../../layouts/BaseLayaout.astro";
import { SERVICE_DATA } from "../../consts";
import PrincipalForm from "../../components/PrincipalForm/index.astro";
import Button from "../../components/Button/index.astro";

export function getStaticPaths() {
  return SERVICE_DATA.services.flatMap((service) => ({
    params: { nameServices: service.nameUrl },
  }));
}

const { nameServices } = Astro.params;
const currentService = SERVICE_DATA.services.find(
  (service) => service.nameUrl === nameServices
);

if (!currentService) {
  return Astro.redirect("/404");
}

const { sectionTitle, sectionSubtitle, subTitle, subText, items, urlImage } =
  currentService;
---

<BaseLayout title={sectionTitle} description={sectionSubtitle}>
  <!-- Hero Section -->
  <section class="relative min-h-[600px] lg:min-h-[700px] flex items-center overflow-hidden">
    <!-- Background Image with Overlay -->
    <div class="absolute inset-0 z-0">
      <img
        src={urlImage}
        alt={sectionTitle}
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/60 to-transparent"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-sky-900/60 via-transparent to-transparent"></div>
    </div>

    <!-- Decorative Elements -->
    <div class="absolute inset-0 z-10 opacity-20 pointer-events-none">
      <div class="absolute top-20 right-20 w-72 h-72 bg-sky-500 rounded-full blur-3xl"></div>
      <div class="absolute bottom-20 left-20 w-96 h-96 bg-sky-400 rounded-full blur-3xl"></div>
    </div>

    <!-- Content -->
    <div class="relative z-20 container mx-auto px-6 lg:px-10 py-20">
      <div class="max-w-3xl">
        <!-- Breadcrumb -->
        <nav class="flex items-center gap-2 text-sm text-white/80 mb-6">
          <a href="/" class="hover:text-white transition-colors">Home</a>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
          <a href="/#servicios" class="hover:text-white transition-colors">Services</a>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
          <span class="text-white font-medium">{sectionTitle}</span>
        </nav>

        <!-- Badge -->
        <div class="inline-flex items-center gap-2 bg-sky-500/20 backdrop-blur-sm border border-sky-400/30 rounded-full px-5 py-2 mb-6">
          <svg class="w-5 h-5 text-sky-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </svg>
          <span class="text-white text-sm font-medium tracking-wide">Professional Service</span>
        </div>

        <!-- Title -->
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-white leading-tight mb-6 animate-fade-in">
          {sectionTitle}
        </h1>

        <!-- Subtitle -->
        <p class="text-xl md:text-2xl text-gray-100 leading-relaxed mb-8 animate-fade-in-delay">
          {sectionSubtitle}
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 animate-fade-in-delay-2">
          <Button text="Get a Free Quote" href="#contact-form" />
          <a 
            href="#services-details" 
            class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-white/10 backdrop-blur-sm border-2 border-white/30 text-white font-semibold rounded-xl hover:bg-white/20 transition-all duration-300 group"
          >
            <span>Learn More</span>
            <svg class="w-5 h-5 transform group-hover:translate-y-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
            </svg>
          </a>
        </div>

        <!-- Trust Indicators -->
        <div class="flex items-center gap-8 mt-10 text-white/90">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
            <span class="text-sm font-medium">5.0 Rating</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-sky-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
            <span class="text-sm font-medium">Guaranteed Quality</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-20 animate-bounce">
      <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
      </svg>
    </div>
  </section>

  <!-- Services Details Section -->
  <section id="services-details" class="relative py-20 lg:py-32 bg-gradient-to-b from-white via-sky-50 to-white overflow-hidden">
    <!-- Decorative Background -->
    <div class="absolute inset-0 opacity-5 pointer-events-none">
      <div class="absolute top-0 left-0 w-96 h-96 bg-sky-500 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 right-0 w-96 h-96 bg-sky-700 rounded-full blur-3xl"></div>
    </div>

    <div class="relative z-10 container mx-auto px-6 lg:px-10">
      <!-- Section Header -->
      <header class="text-center mb-16 lg:mb-20">
        <div class="inline-flex items-center gap-2 bg-sky-100 border border-sky-200 rounded-full px-5 py-2 mb-6">
          <svg class="w-5 h-5 text-sky-600" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          <span class="text-sky-700 text-sm font-medium tracking-wide">{subTitle}</span>
        </div>
        
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-gray-900 mb-6">
          What We Offer
        </h2>
        <p class="text-xl md:text-2xl text-gray-600 max-w-3xl mx-auto">
          {subText}
        </p>
      </header>

      <!-- Services Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-7xl mx-auto">
        {items.map((item, index) => (
          <article 
            class="group bg-white rounded-2xl overflow-hidden shadow-xl hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 border border-gray-100 hover:border-sky-300 flex flex-col"
            style={`animation: fadeInUp 0.6s ease-out ${index * 0.1}s both;`}
          >
            <!-- Image Container -->
            <div class="relative h-56 overflow-hidden">
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent z-10"></div>
              <img
                class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-700"
                src={item.image}
                alt={item.title}
              />
              <!-- Number Badge -->
              <div class="absolute top-4 left-4 z-20 bg-sky-500 text-white font-bold w-12 h-12 rounded-full flex items-center justify-center text-lg shadow-lg">
                {index + 1}
              </div>
            </div>

            <!-- Content -->
            <div class="flex-1 p-8 flex flex-col">
              <h3 class="text-2xl font-bold text-gray-900 mb-4 group-hover:text-sky-600 transition-colors duration-300">
                {item.title}
              </h3>
              <p class="text-gray-600 leading-relaxed mb-6 flex-grow">
                {item.description}
              </p>

              <!-- CTA Button -->
              <div class="mt-auto">
                <Button text={item.cta} href="#contact-form" />
              </div>
            </div>

            <!-- Hover Effect Border -->
            <div class="absolute inset-0 border-2 border-transparent group-hover:border-sky-500/50 rounded-2xl transition-all duration-500 pointer-events-none"></div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact Form Section -->
  <section id="contact-form" class="relative py-20 lg:py-32 bg-gradient-to-b from-white to-sky-50">
    <div class="container mx-auto px-6 lg:px-10">
      <!-- Section Header -->
      <header class="text-center mb-12 lg:mb-16">
        <div class="inline-flex items-center gap-2 bg-sky-100 border border-sky-200 rounded-full px-5 py-2 mb-6">
          <svg class="w-5 h-5 text-sky-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
          </svg>
          <span class="text-sky-700 text-sm font-medium tracking-wide">Get Started</span>
        </div>
        
        <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
          Request Your Free Quote
        </h2>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">
          Fill out the form below and our team will get back to you within 24 hours
        </p>
      </header>

      <!-- Form Container -->
      <div class="max-w-4xl mx-auto">
        <PrincipalForm services={SERVICE_DATA.services} />
      </div>

      <!-- Additional Info -->
      <div class="mt-16 grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        <div class="text-center">
          <div class="bg-sky-100 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-sky-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-2">Fast Response</h3>
          <p class="text-gray-600 text-sm">We respond within 24 hours</p>
        </div>
        <div class="text-center">
          <div class="bg-sky-100 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-sky-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-2">No Commitment</h3>
          <p class="text-gray-600 text-sm">Free quotes, no obligation</p>
        </div>
        <div class="text-center">
          <div class="bg-sky-100 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-sky-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
            </svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-2">Expert Team</h3>
          <p class="text-gray-600 text-sm">Professional certified staff</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fade-in 0.8s ease-out;
  }

  .animate-fade-in-delay {
    animation: fade-in 0.8s ease-out 0.2s both;
  }

  .animate-fade-in-delay-2 {
    animation: fade-in 0.8s ease-out 0.4s both;
  }

  html {
    scroll-behavior: smooth;
    scroll-padding-top: 100px;
  }
</style>