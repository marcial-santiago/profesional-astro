---
export const prerender = false;

import BaseLayout from "../../../layouts/BaseLayaout.astro";
import { prisma } from "../../../lib/prisma";
import Button from "../../../components/Button/index.astro";
import PrincipalForm from "../../../components/PrincipalForm/index.astro";

export function getStaticPaths() {
  return [
    { params: { category: "cleaning" } },
    { params: { category: "plumbing" } },
    { params: { category: "construction" } },
  ];
}

const { category } = Astro.params;

const categoryLabels: Record<string, string> = {
  cleaning: "Cleaning Services",
  plumbing: "Plumbing Services",
  construction: "Construction Services",
};

const categoryDescriptions: Record<string, string> = {
  cleaning: "Professional cleaning solutions for homes and offices. Spotless results guaranteed.",
  plumbing: "Expert plumbing services from leak repairs to full installations. Fast response, quality work.",
  construction: "Quality construction and remodeling services. From planning to execution, we build it right.",
};

const services = await prisma.workType.findMany({
  where: { category: category as any, isActive: true },
  orderBy: { name: "asc" },
});

type WorkType = typeof services[number];

if (services.length === 0) {
  return Astro.redirect("/services");
}

// Get other categories for cross-navigation
const otherCategories = (["cleaning", "plumbing", "construction"] as const)
  .filter(c => c !== category);

const pageTitle = categoryLabels[category || ""] || `${category} Services`;
const pageDescription = categoryDescriptions[category || ""] || "";
---

<BaseLayout title={pageTitle} description={pageDescription}>

  <!-- Hero -->
  <section class="relative min-h-[60vh] flex items-end overflow-hidden">
    <!-- Background -->
    <div class="absolute inset-0 z-0">
      {services.find((s: WorkType) => s.image)?.image ? (
        <img
          src={services.find((s: WorkType) => s.image)!.image!}
          alt={pageTitle}
          class="w-full h-full object-cover"
        />
      ) : (
        <div class="w-full h-full bg-gradient-to-br from-slate-700 to-slate-900"></div>
      )}
      <div class="absolute inset-0 bg-slate-900/70"></div>
      <div class="absolute bottom-0 left-0 right-0 h-48 bg-linear-to-t from-slate-900 to-transparent"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 pb-16 pt-40 w-full">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm text-white/50 mb-6">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <a href="/services" class="hover:text-white transition-colors">Services</a>
        <span>/</span>
        <span class="text-white">{pageTitle}</span>
      </nav>

      <div class="max-w-3xl">
        <span class="inline-block px-3 py-1 bg-sky-500/20 text-sky-300 text-xs font-semibold rounded-full uppercase tracking-wide mb-4">
          {category}
        </span>
        <h1 class="text-5xl md:text-6xl font-bold text-white leading-tight mb-4">
          {pageTitle}
        </h1>
        <p class="text-xl text-slate-300 mb-8 leading-relaxed">
          {pageDescription}
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="#contact-form">
            <Button text="Get a Free Quote" />
          </a>
          <a
            href="tel:0466018580"
            class="flex items-center gap-2 px-6 py-3 rounded-xl border border-white/30 text-white font-semibold hover:bg-white/10 transition-all duration-200 text-sm"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.56 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            Call Now
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust strip -->
  <section class="bg-sky-600 py-5 px-6">
    <div class="max-w-7xl mx-auto flex flex-wrap items-center justify-center gap-8 text-white text-sm font-medium">
      {[
        { icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`, label: "Licensed & Insured" },
        { icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`, label: "Same-day response" },
        { icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`, label: "Transparent pricing" },
        { icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`, label: "Satisfaction guaranteed" },
      ].map((item) => (
        <div class="flex items-center gap-2">
          <Fragment set:html={item.icon} />
          {item.label}
        </div>
      ))}
    </div>
  </section>

  <!-- Services grid -->
  <section class="py-24 bg-white px-6">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-14">
        <p class="text-sky-600 font-semibold text-sm uppercase tracking-widest mb-2">What We Offer</p>
        <h2 class="text-4xl font-bold text-slate-900 mb-4">{pageTitle} — Available Services</h2>
        <p class="text-slate-500 max-w-2xl mx-auto leading-relaxed">
          Choose from our range of professional {category} services. Each one tailored to your needs.
        </p>
      </div>

      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {services.map((item: WorkType) => (
          <article class="group bg-white rounded-2xl border border-slate-200 overflow-hidden hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
            <!-- Image -->
            <div class="relative h-52 overflow-hidden bg-slate-100">
              {item.image ? (
                <img
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  src={item.image}
                  alt={item.name}
                />
              ) : (
                <div class="w-full h-full flex items-center justify-center bg-slate-200 text-slate-400">
                  <span class="text-4xl">🔧</span>
                </div>
              )}
              <div class="absolute inset-0 bg-linear-to-t from-slate-900/60 to-transparent"></div>
              <div class="absolute top-3 right-3 bg-sky-500 text-white text-xs font-bold px-3 py-1 rounded-full">
                From ${item.price}
              </div>
            </div>

            <!-- Content -->
            <div class="p-6">
              <h3 class="text-lg font-bold text-slate-900 mb-2">{item.name}</h3>
              {item.description && (
                <p class="text-slate-500 text-sm leading-relaxed mb-4">{item.description}</p>
              )}
              <p class="text-xs text-slate-400 mb-4">⏱️ {item.duration} min</p>
              <a
                href={`/services/${item.slug}`}
                class="inline-flex items-center gap-2 w-full justify-center px-5 py-2.5 bg-sky-50 hover:bg-sky-100 text-sky-700 font-semibold text-sm rounded-xl transition-colors duration-200"
              >
                View Details
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Other categories -->
  <section class="py-20 bg-slate-50 px-6">
    <div class="max-w-7xl mx-auto">
      <h2 class="text-2xl font-bold text-slate-900 mb-8">Other Services</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {otherCategories.map((cat) => (
          <a
            href={`/services/cat/${cat}`}
            class="group flex items-center gap-5 bg-white border border-slate-200 rounded-2xl p-5 hover:border-sky-300 hover:bg-sky-50 transition-all duration-200"
          >
            <div class="flex-1 min-w-0">
              <h3 class="font-bold text-slate-900 mb-0.5">{categoryLabels[cat] || cat}</h3>
              <p class="text-slate-500 text-sm">{categoryDescriptions[cat] || ""}</p>
            </div>
            <svg class="text-slate-400 group-hover:text-sky-500 transition-colors shrink-0" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact form -->
  <section id="contact-form" class="scroll-mt-20">
    <PrincipalForm />
  </section>

</BaseLayout>
