---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayaout.astro";
import { STRAPI_URL, strapiImage } from "../../config";
import Button from "../../components/Button/index.astro";
import PrincipalForm from "../../components/PrincipalForm/index.astro";

const { slug } = Astro.params;

interface WorkTypeImage {
  url: string;
}

interface StrapiWorkType {
  id: number;
  name: string;
  slug: string;
  description: string | null;
  category: string;
  duration: number;
  price: number;
  isActive: boolean;
  image: WorkTypeImage | null;
}

// Fetch single service by slug
const serviceRes = await fetch(`${STRAPI_URL}/api/work-types?filters[slug][$eq]=${slug}&filters[isActive][$eq]=true&populate=image`);
const serviceData = await serviceRes.json();
const strapiService: StrapiWorkType | undefined = serviceData.data?.[0];

if (!strapiService) {
  return Astro.redirect("/404");
}

// Transform to match existing format
const service = {
  id: strapiService.id,
  name: strapiService.name,
  slug: strapiService.slug,
  description: strapiService.description,
  category: strapiService.category,
  duration: strapiService.duration,
  price: strapiService.price,
  isActive: strapiService.isActive,
  image: strapiService.image ? { path: strapiImage(strapiService.image.url) } : null,
};

// Get other services for "Other Services" section
const otherRes = await fetch(`${STRAPI_URL}/api/work-types?filters[slug][$ne]=${slug}&filters[isActive][$eq]=true&populate=image&pagination[limit]=3`);
const otherData = await otherRes.json();
const strapiOthers: StrapiWorkType[] = otherData.data || [];

const otherServices = strapiOthers.map((wt) => ({
  id: wt.id,
  name: wt.name,
  slug: wt.slug,
  description: wt.description,
  category: wt.category,
  duration: wt.duration,
  price: wt.price,
  isActive: wt.isActive,
  image: wt.image ? { path: strapiImage(wt.image.url) } : null,
}));

type WorkType = typeof otherServices[number];
---

<BaseLayout title={service.name} description={service.description || ""}>

  <!-- Hero -->
  <section class="relative min-h-[70vh] flex items-end overflow-hidden">
    <!-- Background -->
    <div class="absolute inset-0 z-0">
      {service.image?.path ? (
        <img
          src={service.image.path}
          alt={service.name}
          class="w-full h-full object-cover"
        />
      ) : (
        <div class="w-full h-full bg-gradient-to-br from-slate-700 to-slate-900"></div>
      )}
      <div class="absolute inset-0 bg-slate-900/70"></div>
      <div class="absolute bottom-0 left-0 right-0 h-48 bg-linear-to-t from-slate-900 to-transparent"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 pb-16 pt-40 w-full">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm text-white/50 mb-6">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <a href="/services" class="hover:text-white transition-colors">Services</a>
        <span>/</span>
        <span class="text-white">{service.name}</span>
      </nav>

      <div class="max-w-3xl">
        <span class="inline-block px-3 py-1 bg-sky-500/20 text-sky-300 text-xs font-semibold rounded-full uppercase tracking-wide mb-4">
          {service.category}
        </span>
        <h1 class="text-5xl md:text-6xl font-bold text-white leading-tight mb-4">
          {service.name}
        </h1>
        {service.description && (
          <p class="text-xl text-slate-300 mb-8 leading-relaxed">
            {service.description}
          </p>
        )}
        <div class="flex flex-wrap gap-4 items-center">
          <a href="#contact-form">
            <Button text="Get a Free Quote" />
          </a>
          <a
            href="tel:0466018580"
            class="flex items-center gap-2 px-6 py-3 rounded-xl border border-white/30 text-white font-semibold hover:bg-white/10 transition-all duration-200 text-sm"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.56 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            Call Now
          </a>
          <span class="text-white/60 text-sm">
            ⏱️ {service.duration} min · From ${service.price}
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust strip -->
  <section class="bg-sky-600 py-5 px-6">
    <div class="max-w-7xl mx-auto flex flex-wrap items-center justify-center gap-8 text-white text-sm font-medium">
      {[
        { icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`, label: "Licensed & Insured" },
        { icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`, label: "Same-day response" },
        { icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`, label: "Transparent pricing" },
        { icon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`, label: "Satisfaction guaranteed" },
      ].map((item) => (
        <div class="flex items-center gap-2">
          <Fragment set:html={item.icon} />
          {item.label}
        </div>
      ))}
    </div>
  </section>

  <!-- Contact form -->
  <section id="contact-form" class="scroll-mt-20">
    <PrincipalForm />
  </section>

  <!-- Other services -->
  {otherServices.length > 0 && (
    <section class="py-20 bg-white px-6">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-2xl font-bold text-slate-900 mb-8">Other Services</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {otherServices.map((s: WorkType) => (
            <a
              href={`/services/${s.slug}`}
              class="group flex items-center gap-5 bg-slate-50 border border-slate-200 rounded-2xl p-5 hover:border-sky-300 hover:bg-sky-50 transition-all duration-200"
            >
              <div class="w-16 h-16 rounded-xl overflow-hidden shrink-0 bg-slate-200 flex items-center justify-center">
                {s.image?.path ? (
                  <img src={s.image.path} alt={s.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
                ) : (
                  <span class="text-xl text-slate-400">🔧</span>
                )}
              </div>
              <div class="flex-1 min-w-0">
                <h3 class="font-bold text-slate-900 mb-0.5">{s.name}</h3>
                <p class="text-slate-500 text-sm truncate">{s.description || s.category}</p>
              </div>
              <svg class="text-slate-400 group-hover:text-sky-500 transition-colors shrink-0" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

</BaseLayout>
