---
export const prerender = false;
import BaseLayaout from "../../layouts/BaseLayaout.astro";
---

<BaseLayaout>
  <div class="min-h-screen bg-slate-50 flex items-center justify-center px-4">
    <div class="text-center max-w-sm">
      <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6">
        <svg class="w-10 h-10 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <h1 class="text-2xl font-bold text-slate-900 mb-2">¡Pago exitoso!</h1>
      <p class="text-slate-500 text-sm mb-8">
        Recibimos tu pago y tu solicitud de visita. Te contactamos pronto para confirmar el horario.
      </p>
      <a
        href="/"
        class="inline-block bg-blue-600 text-white px-6 py-2.5 rounded-xl text-sm font-medium hover:bg-blue-700 transition"
      >
        Volver al inicio
      </a>
    </div>
  </div>
</BaseLayaout>
