# ── Production Environment Variables ──
# Copy to .env and fill in all values before deploying:
#   cp .env.prod.example .env

# ── Database (PostgreSQL) ──
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_strong_password
DB_NAME=profesional_astro

# ── Strapi ──
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
APP_KEYS=CHANGE_ME_key1,CHANGE_ME_key2,CHANGE_ME_key3,CHANGE_ME_key4
API_TOKEN_SALT=CHANGE_ME_random
ADMIN_JWT_SECRET=CHANGE_ME_random
JWT_SECRET=CHANGE_ME_random
TRANSFER_TOKEN_SALT=CHANGE_ME_random

# ── Astro ──
# Generated AFTER first Strapi boot — go to /strapi/admin → Settings → API Tokens
STRAPI_API_TOKEN=CHANGE_ME_generate_after_first_boot

# Stripe (get from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# Admin panel credentials
ADMIN_USER=admin
ADMIN_PASSWORD=CHANGE_ME_strong_password
ADMIN_SESSION_SECRET=CHANGE_ME_random_long_string

# Allowed origins (comma-separated, no spaces)
ALLOWED_ORIGINS=https://tu-dominio.com,http://localhost
APP_TIMEZONE=America/Argentina/Buenos_Aires
